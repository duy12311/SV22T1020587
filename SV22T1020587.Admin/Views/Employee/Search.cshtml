@model SV22T1020587.Models.Common.PagedResult<SV22T1020587.Models.HR.Employee>
@{
    Layout = null; // Cực kỳ quan trọng để không bị lồng giao diện Layout
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> nhân viên
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th class="text-center" style="width: 80px;">Ảnh</th>
                        <th>Họ và tên</th>
                        <th>Ngày sinh</th>
                        <th>Liên hệ</th>
                        <th class="text-center">Trạng thái</th>
                        <th class="text-center" style="width: 160px;">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model.DataItems)
                    {
                        <tr>
                            <td class="text-center align-middle">
                                <img src="~/images/employees/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                     style="width:50px; height:50px; object-fit:cover" class="rounded shadow-sm" />
                            </td>
                            <td class="align-middle">@item.FullName</td>
                            <td class="align-middle">@item.BirthDate?.ToString("dd/MM/yyyy")</td>
                            <td class="align-middle">
                                <small><i class="bi bi-telephone"></i> @item.Phone</small><br />
                                <small><i class="bi bi-envelope"></i> @item.Email</small>
                            </td>
                            <td class="text-center align-middle">
                                @if (item.IsWorking == true)
                                {
                                    <span class="badge bg-success">Đang làm việc</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">Đã nghỉ việc</span>
                                }
                            </td>
                            <td class="text-center text-nowrap align-middle">
                                <a href="~/Employee/Edit/@item.EmployeeID" class="btn btn-sm btn-primary" title="Cập nhật"><i class="bi bi-pencil"></i></a>
                                <a href="~/Employee/Delete/@item.EmployeeID" class="btn btn-sm btn-danger" title="Xóa"><i class="bi bi-trash"></i></a>
                                <a href="~/Employee/ChangePassword/@item.EmployeeID" class="btn btn-sm btn-warning" title="Đổi mật khẩu"><i class="bi bi-key"></i></a>
                                <a href="~/Employee/ChangeRole/@item.EmployeeID" class="btn btn-sm btn-info" title="Phân quyền"><i class="bi bi-shield-check"></i></a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center m-0">
                <li class="page-item @(Model.Page == 1 ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" onclick="doSearch(1)"><i class="bi bi-chevron-double-left"></i></a>
                </li>
                @{
                    int delta = 2; // Hiển thị 2 trang xung quanh trang hiện tại
                    int start = Math.Max(1, Model.Page - delta);
                    int end = Math.Min(Model.PageCount, Model.Page + delta);

                    if (end - start < 4)
                    {
                        if (start == 1) end = Math.Min(Model.PageCount, 5);
                        else start = Math.Max(1, end - 4);
                    }
                }
                @for (int i = start; i <= end; i++)
                {
                    <li class="page-item @(i == Model.Page ? "active" : "")">
                        <a class="page-link" href="javascript:;" onclick="doSearch(@i)">@i</a>
                    </li>
                }
                <li class="page-item @(Model.Page == Model.PageCount ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" onclick="doSearch(@Model.PageCount)"><i class="bi bi-chevron-double-right"></i></a>
                </li>
            </ul>
        </div>
    }
</div>