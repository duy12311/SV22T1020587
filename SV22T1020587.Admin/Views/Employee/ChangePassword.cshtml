@model SV22T1020587.Models.HR.Employee
@{
    ViewBag.Title = "Thiết lập mật khẩu";
}

@section PageToolBar {
    <button type="submit" form="formChangePassword" class="btn btn-primary" onclick="return confirm('Xác nhận thay đổi mật khẩu mới?')">
        <i class="bi bi-shield-check me-1"></i> Cập nhật mật khẩu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        @* THÔNG BÁO THÀNH CÔNG *@
        @if (TempData["Message"] != null)
        {
            <div id="password-alert" class="alert alert-success alert-dismissible fade show shadow-sm mb-3 border-start border-success border-4">
                <i class="bi bi-patch-check-fill me-2"></i> <strong>Tuyệt vời!</strong> @TempData["Message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card card-warning card-outline shadow-sm">
            <div class="card-header"><h5 class="card-title mb-0"><i class="bi bi-key-fill me-2"></i>Đổi mật khẩu</h5></div>
            <div class="card-body">
                <form id="formChangePassword" action="~/Employee/SavePassword" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="employeeID" value="@Model.EmployeeID" />

                    <div class="alert alert-info py-2">
                        <small><i class="bi bi-person-circle me-1"></i> Tài khoản: <strong>@Model.Email</strong></small>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu mới</label>
                        <input type="password"
                               class="form-control @(ViewData.ModelState.ContainsKey("newPassword") && ViewData.ModelState["newPassword"].Errors.Count > 0 ? "is-invalid" : "")"
                               name="newPassword"
                               placeholder="Nhập mật khẩu mới" autofocus />
                        @* Hiển thị lỗi mật khẩu mới *@
                        @Html.ValidationMessage("newPassword", "", new { @class = "text-danger small fw-bold" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Xác nhận lại mật khẩu</label>
                        <input type="password"
                               class="form-control @(ViewData.ModelState.ContainsKey("confirmPassword") && ViewData.ModelState["confirmPassword"].Errors.Count > 0 ? "is-invalid" : "")"
                               name="confirmPassword"
                               placeholder="Nhập lại mật khẩu" />
                        @* Hiển thị lỗi không khớp *@
                        @Html.ValidationMessage("confirmPassword", "", new { @class = "text-danger small fw-bold" })
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            setTimeout(function () {
                $("#password-alert").fadeOut("slow");
            }, 4000);
        });
    </script>
}