@model SV22T1020587.Models.HR.Employee
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary"><i class="bi bi-save"></i> Lưu dữ liệu</button>
    <a href="~/Employee" class="btn btn-secondary ms-1"><i class="bi bi-arrow-left"></i> Quay lại</a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="bi bi-person-badge me-2"></i>Thông tin nhân viên</h5>
            </div>
            <div class="card-body">
                @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

                <form id="formEdit" action="~/Employee/Save" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="EmployeeID" value="@Model.EmployeeID" />
                    <input type="hidden" name="Photo" value="@Model.Photo" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Họ và tên</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="FullName" value="@Model.FullName" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ngày sinh (dd/mm/yyyy)</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control date-picker" name="birthDateInput"
                                   value="@Model.BirthDate?.ToString("dd/MM/yyyy")" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Email</label>
                        <div class="col-sm-9">
                            <input type="email" class="form-control" name="Email" value="@Model.Email" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Điện thoại</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="Phone" value="@Model.Phone" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Địa chỉ</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="Address" value="@Model.Address" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh đại diện</label>
                        <div class="col-sm-9">
                            <input type="file" class="form-control" name="uploadPhoto" accept="image/*" onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            <div class="mt-2">
                                <img id="imgPreview" src="~/images/employees/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)" class="img-thumbnail" style="max-height: 150px; max-width: 150px; object-fit: cover;" />
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="IsWorking" name="IsWorking" value="true" @(Model.IsWorking == true ? "checked" : "") />
                                <input type="hidden" name="IsWorking" value="false" />
                                <label class="form-check-label" for="IsWorking">Đang làm việc</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>