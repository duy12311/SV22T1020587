@model SV22T1020587.Models.HR.Employee
@{
    ViewBag.Title = Model.EmployeeID == 0 ? "Bổ sung nhân viên" : "Cập nhật nhân viên";
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary" onclick="return confirm('Xác nhận lưu dữ liệu?')">
        <i class="bi bi-save me-1"></i> Lưu dữ liệu
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        @* HIỂN THỊ THÔNG BÁO KHI LƯU XONG *@
        @if (TempData["Message"] != null)
        {
            <div id="msg-alert" class="alert alert-success alert-dismissible fade show shadow-sm mb-3">
                <i class="bi bi-check-circle-fill me-2"></i> @TempData["Message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card card-primary card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0"><i class="bi bi-person-badge me-2"></i>Thông tin nhân viên</h5>
            </div>
            <div class="card-body">
                @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

                <form id="formEdit" action="~/Employee/Save" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="EmployeeID" value="@Model.EmployeeID" />
                    <input type="hidden" name="Photo" value="@Model.Photo" />

                    @* Họ và tên *@
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">Họ và tên</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="FullName" value="@Model.FullName" required autofocus />
                        </div>
                    </div>

                    @* Ngày sinh *@
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">Ngày sinh (dd/mm/yyyy)</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control date-picker" name="birthDateInput"
                                   value="@Model.BirthDate?.ToString("dd/MM/yyyy")" />
                        </div>
                    </div>

                    @* Địa chỉ *@
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">Địa chỉ</label>
                        <div class="col-sm-9">
                            <input type="text" class="form-control" name="Address" value="@Model.Address" />
                        </div>
                    </div>

                    @* Email *@
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">Email</label>
                        <div class="col-sm-9">
                            <input type="email" class="form-control" name="Email" value="@Model.Email" required />
                        </div>
                    </div>

                    @* SỐ ĐIỆN THOẠI - ĐÃ ĐƯỢC THÊM LẠI *@
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">Số điện thoại</label>
                        <div class="col-sm-9">
                            <input type="tel" class="form-control" name="Phone" value="@Model.Phone" placeholder="Nhập số điện thoại nhân viên" />
                        </div>
                    </div>

                    @* Ảnh đại diện *@
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">Ảnh đại diện</label>
                        <div class="col-sm-9">
                            <input type="file" class="form-control" name="uploadPhoto" accept="image/*"
                                   onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            <div class="mt-2 text-center text-sm-start">
                                <img id="imgPreview" src="~/images/employees/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                     class="img-thumbnail" style="height: 120px;" />
                            </div>
                        </div>
                    </div>

                    @* Trạng thái *@
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch mt-2">
                                <input class="form-check-input" type="checkbox" id="IsWorking" name="IsWorking" value="true" @(Model.IsWorking == true ? "checked" : "") />
                                <input type="hidden" name="IsWorking" value="false" />
                                <label class="form-check-label" for="IsWorking">Đang làm việc</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            // Tự động ẩn thông báo sau 3 giây
            setTimeout(function () {
                $("#msg-alert").fadeOut("slow");
            }, 3000);
        });
    </script>
}