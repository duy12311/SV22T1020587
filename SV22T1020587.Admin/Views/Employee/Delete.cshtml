@model SV22T1020587.Models.HR.Employee
@{
    ViewBag.Title = "Xóa nhân viên";
}
@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger" onclick="return confirm('Hành động xóa nhân viên không thể khôi phục. Bạn có chắc chắn muốn thực hiện?')">
        <i class="bi bi-trash me-1"></i> Xác nhận xóa
    </button>
    <a href="~/Employee" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="card card-danger card-outline shadow-sm">
    <div class="card-header">
        <h3 class="card-title text-danger fw-bold"><i class="bi bi-person-x me-2"></i> Xác nhận xóa nhân viên</h3>
    </div>

    <div class="card-body">
        @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

        @if (TempData["Error"] != null)
        {
            <div class="alert alert-danger mb-3">
                <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
            </div>
        }

        @* Action trỏ thẳng về URL gốc, giá trị truyền ngầm qua input hidden *@
        <form id="formDelete" action="~/Employee/Delete" method="post">
            @Html.AntiForgeryToken()

            @* QUAN TRỌNG: Name bắt buộc phải là "id" để khớp với tham số trong Controller *@
            <input type="hidden" name="id" value="@Model.EmployeeID" />

            <div class="alert alert-warning d-flex align-items-center">
                <i class="bi bi-exclamation-triangle-fill fs-4 me-2"></i>
                <div>Dữ liệu nhân viên sẽ bị xóa vĩnh viễn. Bạn có chắc chắn không?</div>
            </div>

            <div class="row align-items-center">
                <div class="col-md-auto text-center mb-3 mb-md-0">
                    <img src="~/images/employees/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                         class="img-thumbnail rounded shadow-sm" style="width: 150px; height: 150px; object-fit: cover;" alt="Ảnh nhân viên" />
                </div>
                <div class="col-md">
                    <dl class="row mb-0 px-3">
                        <dt class="col-sm-3 text-muted">Họ và tên:</dt>
                        <dd class="col-sm-9 fw-bold">@Model.FullName</dd>

                        <dt class="col-sm-3 text-muted">Ngày sinh:</dt>
                        <dd class="col-sm-9">@Model.BirthDate?.ToString("dd/MM/yyyy")</dd>

                        <dt class="col-sm-3 text-muted">Liên hệ:</dt>
                        <dd class="col-sm-9">@Model.Phone - @Model.Email</dd>

                        <dt class="col-sm-3 text-muted">Địa chỉ:</dt>
                        <dd class="col-sm-9">@Model.Address</dd>

                        <dt class="col-sm-3 text-muted">Trạng thái:</dt>
                        <dd class="col-sm-9">
                            @if (Model.IsWorking == true)
                            {
                                <span class="badge bg-success">Đang làm việc</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary">Đã nghỉ việc</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </form>
    </div>
</div>