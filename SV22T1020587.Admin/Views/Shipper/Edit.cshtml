@model SV22T1020587.Models.Partner.Shipper
@{
    ViewBag.Title = Model.ShipperID == 0 ? "Bổ sung người giao hàng" : "Cập nhật người giao hàng";
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary" onclick="return confirm('Bạn có chắc chắn muốn lưu thông tin người giao hàng này không?')">
        <i class="bi bi-save me-1"></i> Lưu dữ liệu
    </button>
    <a href="~/Shipper" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        @* HIỂN THỊ THÔNG BÁO THÀNH CÔNG *@
        @if (TempData["Message"] != null)
        {
            <div id="shipper-alert" class="alert alert-success alert-dismissible fade show shadow-sm mb-3 border-start border-success border-4">
                <i class="bi bi-check-circle-fill me-2"></i>
                <strong>Thành công!</strong> @TempData["Message"]
                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
            </div>
        }

        <div class="card card-primary card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-bicycle me-2 text-primary"></i> @ViewBag.Title
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Shipper/Save" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ShipperID" value="@Model.ShipperID" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên người giao hàng</label>
                        <input type="text"
                               class="form-control @(ViewData.ModelState.ContainsKey(nameof(Model.ShipperName)) && ViewData.ModelState[nameof(Model.ShipperName)].Errors.Count > 0 ? "is-invalid" : "")"
                               name="ShipperName"
                               value="@Model.ShipperName"
                               placeholder="Nhập tên người giao hàng" autofocus />
                        @Html.ValidationMessage(nameof(Model.ShipperName), new { @class = "text-danger small mt-1 fw-bold" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Điện thoại</label>
                        <input type="tel"
                               class="form-control @(ViewData.ModelState.ContainsKey(nameof(Model.Phone)) && ViewData.ModelState[nameof(Model.Phone)].Errors.Count > 0 ? "is-invalid" : "")"
                               name="Phone"
                               value="@Model.Phone"
                               placeholder="Nhập số điện thoại" />
                        @Html.ValidationMessage(nameof(Model.Phone), new { @class = "text-danger small mt-1 fw-bold" })
                    </div>

                    @Html.ValidationMessage("Error", new { @class = "alert alert-danger d-block mt-2 small" })
                </form>
            </div>
        </div>
    </div>
</div>

@section scripts {
    <script>
        $(document).ready(function () {
            // Tự động ẩn thông báo thành công sau 3 giây
            setTimeout(function () {
                $("#shipper-alert").fadeOut("slow");
            }, 3000);
        });
    </script>
}