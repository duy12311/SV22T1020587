@using System.Security.Claims
@{
    // Truy xuất các thông tin đã lưu trong Cookie lúc đăng nhập
    var user = Context.User;
    var displayName = user.FindFirst(ClaimTypes.GivenName)?.Value ?? "Người dùng";
    var photo = user.FindFirst("Photo")?.Value ?? "default-user.png";

    // Nếu ảnh trong DB chỉ là tên file, ta nối thêm đường dẫn thư mục ảnh nhân viên
    // Giả sử ảnh bạn để trong wwwroot/images/employees/
    var photoPath = photo.StartsWith("http") ? photo : Url.Content($"~/images/employees/{photo}");
}

<nav class="app-header navbar navbar-expand bg-body-secondary">
    <div class="container-fluid">
        <ul class="navbar-nav">
            <li class="nav-item">
                <a class="nav-link" data-lte-toggle="sidebar" href="#" role="button">
                    <i class="bi bi-list"></i>
                </a>
            </li>
            <li class="nav-item d-none d-md-block"><a href="~/" class="nav-link">Trang chủ</a></li>
        </ul>

        <ul class="navbar-nav ms-auto">
            <li class="nav-item dropdown user-menu">
                <a href="#" class="nav-link dropdown-toggle" data-bs-toggle="dropdown">
                    @* Hiển thị ảnh đại diện động *@
                    <img src="@photoPath" class="user-image rounded-circle shadow" alt="User Image"
                         onerror="this.src='/lib/adminlte/assets/img/user2-160x160.jpg'" />

                    @* Hiển thị tên động *@
                    <span class="d-none d-md-inline">@displayName</span>
                </a>

                <ul class="dropdown-menu dropdown-menu-lg dropdown-menu-end">
                    <li class="user-header text-bg-primary">
                        <img src="@photoPath" class="rounded-circle shadow" alt="User Image"
                             onerror="this.src='/lib/adminlte/assets/img/user2-160x160.jpg'" />
                        <p>
                            @displayName
                            <small>@user.FindFirst(ClaimTypes.Email)?.Value</small>
                        </p>
                    </li>

                    <li class="user-footer">
                        <a href="~/Account/ChangePassword" class="btn btn-default btn-flat">Đổi mật khẩu</a>
                        <a href="~/Account/Logout" class="btn btn-default btn-flat float-end">Đăng Xuất</a>
                    </li>
                </ul>
            </li>
        </ul>
    </div>
</nav>