@model SV22T1020587.Models.Catalog.Product
@{
    Layout = null;
    var attributes = ViewBag.Attributes as IEnumerable<SV22T1020587.Models.Catalog.ProductAttribute>;
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-success card-outline mt-4 shadow-sm">
            <div class="card-header">
                <div class="row align-items-center">
                    <div class="col">
                        <h6 id="attributes" class="card-title mb-0 fw-bold text-success">
                            <i class="bi bi-list-check me-2"></i> Thuộc tính mặt hàng
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/Attribute/@Model.ProductID?method=add">
                            <i class="bi bi-plus-lg"></i> Thêm thuộc tính
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                @* --- THÔNG BÁO RIÊNG CHO PHẦN THUỘC TÍNH --- *@
                @if (TempData["AttributeMessage"] != null)
                {
                    <div class="alert alert-info alert-dismissible fade show m-2" role="alert">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        @TempData["AttributeMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th class="text-nowrap">Tên thuộc tính</th>
                                <th class="text-nowrap">Giá trị</th>
                                <th style="width:120px" class="text-center text-nowrap">Thứ tự</th>
                                <th style="width:120px" class="text-center text-nowrap">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (attributes != null && attributes.Any())
                            {
                                foreach (var item in attributes)
                                {
                                    <tr>
                                        <td class="align-middle fw-bold text-secondary">@item.AttributeName</td>
                                        <td class="align-middle">@item.AttributeValue</td>
                                        <td class="text-center align-middle">
                                            <span class="badge rounded-pill bg-light text-dark border">@item.DisplayOrder</span>
                                        </td>
                                        <td class="text-center align-middle text-nowrap">
                                            <a class="btn btn-sm btn-outline-primary me-1"
                                               href="~/Product/Attribute/@Model.ProductID?method=edit&attributeId=@item.AttributeID"
                                               title="Chỉnh sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a class="btn btn-sm btn-outline-danger"
                                               href="~/Product/Attribute/@Model.ProductID?method=delete&attributeId=@item.AttributeID"
                                               onclick="return confirm('Xác nhận xóa thuộc tính này?')"
                                               title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="4" class="text-center text-muted p-4">
                                        <i class="bi bi-inbox fs-2 d-block mb-2"></i>
                                        Chưa có thuộc tính nào cho mặt hàng này.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

@* Script bổ sung nếu Partial View này được load độc lập hoặc cần auto-hide *@
<script>
    setTimeout(function () {
        $(".alert").fadeOut('slow');
    }, 3000);
</script>