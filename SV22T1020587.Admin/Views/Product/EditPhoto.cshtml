@model SV22T1020587.Models.Catalog.ProductPhoto
@{
    ViewBag.Title = Model.PhotoID == 0 ? "Bổ sung ảnh mặt hàng" : "Cập nhật ảnh mặt hàng";
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu ảnh
    </button>
    <a href="~/Product/Edit/@Model.ProductID#photos" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

@* --- PHẦN HIỂN THỊ THÔNG BÁO --- *@
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-outline card-info">
            <div class="card-header">
                <h5 class="mb-0">
                    <i class="bi bi-image me-2"></i> Thông tin ảnh mặt hàng
                </h5>
            </div>
            <div class="card-body">
                <form id="formEdit" action="~/Product/SavePhoto" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="PhotoID" value="@Model.PhotoID" />
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />
                    <input type="hidden" name="Photo" value="@Model.Photo" />

                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-3 fw-semibold">Chọn ảnh</label>
                        <div class="col-sm-9">
                            <input type="file" name="uploadPhoto" class="form-control" accept="image/*"
                                   onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            @Html.ValidationMessage("uploadPhoto", new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Xem trước</label>
                        <div class="col-sm-9">
                            <img id="imgPreview" src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                 class="img-thumbnail shadow-sm" style="max-height:160px;" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Mô tả ảnh</label>
                        <div class="col-sm-9">
                            <input type="text" name="Description" class="form-control" value="@Model.Description" placeholder="Ví dụ: Ảnh mặt trước, Ảnh chi tiết..." />
                            @Html.ValidationMessage(nameof(Model.Description), new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 fw-semibold">Thứ tự hiển thị</label>
                        <div class="col-sm-3">
                            <input type="number" name="DisplayOrder" class="form-control" value="@Model.DisplayOrder" min="1" />
                            @Html.ValidationMessage(nameof(Model.DisplayOrder), new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="row mb-4">
                        <label class="col-sm-3 fw-semibold">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check form-switch">
                                <input class="form-check-input" type="checkbox" name="IsHidden" id="IsHidden" value="true" @(Model.IsHidden ? "checked" : "") />
                                <label class="form-check-label" for="IsHidden">Ẩn ảnh này khỏi khách hàng</label>
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            // Tự động ẩn thông báo lỗi sau 4 giây
            setTimeout(function () {
                $(".alert-danger").fadeOut('slow');
            }, 4000);
        });
    </script>
}