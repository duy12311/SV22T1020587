@{
    ViewBag.Title = "Quản lý Mặt hàng";
}

@section PageToolBar {
    <a href="~/Product/Create" class="btn btn-primary">
        <i class="bi bi-plus-circle me-1"></i> Bổ sung
    </a>
}

@* --- PHẦN HIỂN THỊ THÔNG BÁO --- *@
@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert" id="success-alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert" id="error-alert">
        <i class="bi bi-exclamation-triangle-fill me-2"></i>
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Product/Search" method="post" data-target="searchResult">
            <input type="hidden" name="PageSize" value="20" />
            <div class="row g-2">
                <div class="col-md-3">
                    <label class="form-label">Loại hàng</label>
                    <select name="CategoryID" class="form-select">
                        <option value="0">-- Tất cả --</option>
                        @if (ViewBag.Categories != null)
                        {
                            foreach (var item in ViewBag.Categories)
                            {
                                if (item.CategoryID == ViewBag.CategoryID)
                                {
                                    <option value="@item.CategoryID" selected>@item.CategoryName</option>
                                }
                                else
                                {
                                    <option value="@item.CategoryID">@item.CategoryName</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <label class="form-label">Nhà cung cấp</label>
                    <select name="SupplierID" class="form-select">
                        <option value="0">-- Tất cả --</option>
                        @if (ViewBag.Suppliers != null)
                        {
                            foreach (var item in ViewBag.Suppliers)
                            {
                                if (item.SupplierID == ViewBag.SupplierID)
                                {
                                    <option value="@item.SupplierID" selected>@item.SupplierName</option>
                                }
                                else
                                {
                                    <option value="@item.SupplierID">@item.SupplierName</option>
                                }
                            }
                        }
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label">Khoảng giá</label>
                    <div class="input-group">
                        <input type="text" name="minPrice" class="form-control number-separator" placeholder="Từ..." value="@ViewBag.MinPrice" />
                        <span class="input-group-text">-</span>
                        <input type="text" name="maxPrice" class="form-control number-separator" placeholder="Đến..." value="@ViewBag.MaxPrice" />
                    </div>
                </div>
                <div class="col-md-4">
                    <label class="form-label">Tên mặt hàng</label>
                    <div class="input-group">
                        <input type="text" name="searchValue" class="form-control" placeholder="Nhập tên mặt hàng..." value="@ViewBag.SearchValue" autofocus />
                        <button class="btn btn-info d-flex align-items-center" type="submit">
                            <i class="bi bi-search me-1"></i> Tìm kiếm
                        </button>
                    </div>
                </div>
            </div>
        </form>
    </div>
</div>

<div id="searchResult">
</div>

@section Scripts {
    <script>
        (function () {
            // Tự động đóng thông báo sau 3 giây
            setTimeout(function () {
                $(".alert").fadeOut('slow', function() {
                    $(this).alert('close');
                });
            }, 3000);

            function doSearch(page) {
                var $form = $('#formSearch');
                if ($form.length === 0) return;
                var data = $form.serializeArray().filter(function (f) { return f.name !== 'Page'; });
                data.push({ name: 'Page', value: page });

                $.ajax({
                    url: $form.prop('action'),
                    type: ($form.prop('method') || 'POST').toUpperCase(),
                    data: data,
                    success: function (html) {
                        $('#searchResult').html(html);
                    },
                    error: function (xhr, status, err) {
                        console.error('Product search failed', status, err);
                        alert('Không thể tải dữ liệu. Kiểm tra console (F12).');
                    }
                });
            }

            $(function () {
                doSearch(@(ViewBag.Page ?? 1));

                $('#formSearch').on('submit', function (e) {
                    e.preventDefault();
                    doSearch(1);
                });

                $('#searchResult').on('click', '.pagination .page-link', function (e) {
                    e.preventDefault();
                    var $a = $(this);
                    var $li = $a.closest('.page-item');
                    if ($li.hasClass('disabled') || $li.hasClass('active')) return;

                    var page = $a.data('page');
                    if (!page) {
                        var text = $a.text().trim();
                        var n = parseInt(text, 10);
                        if (!isNaN(n)) page = n;
                    }
                    if (!page) return;
                    doSearch(page);
                });
            });
        })();
    </script>
}