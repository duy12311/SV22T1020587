@model SV22T1020587.Models.Catalog.Product
@{
    ViewBag.Title = Model.ProductID == 0 ? "Bổ sung mặt hàng" : "Cập nhật mặt hàng";
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu dữ liệu
    </button>
    <a href="~/Product" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-box-seam me-2"></i> Thông tin mặt hàng
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Product/Save" method="post" enctype="multipart/form-data">
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />
                    <input type="hidden" name="Photo" value="@Model.Photo" />

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Tên mặt hàng</label>
                        <div class="col-sm-9">
                            <input type="text" name="ProductName" class="form-control" value="@Model.ProductName" placeholder="Nhập tên mặt hàng" required autofocus />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Mô tả</label>
                        <div class="col-sm-9">
                            <textarea class="form-control" name="ProductDescription" rows="3" placeholder="Nhập mô tả mặt hàng">@Model.ProductDescription</textarea>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Loại hàng</label>
                        <div class="col-sm-9">
                            <select class="form-select" name="CategoryID">
                                <option value="0">-- Chọn loại hàng --</option>
                                @if (ViewBag.Categories != null)
                                {
                                    foreach (var item in ViewBag.Categories)
                                    {
                                        if (item.CategoryID == Model.CategoryID)
                                        {
                                            <option value="@item.CategoryID" selected>@item.CategoryName</option>
                                        }
                                        else
                                        {
                                            <option value="@item.CategoryID">@item.CategoryName</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Nhà cung cấp</label>
                        <div class="col-sm-9">
                            <select class="form-select" name="SupplierID">
                                <option value="0">-- Chọn nhà cung cấp --</option>
                                @if (ViewBag.Suppliers != null)
                                {
                                    foreach (var item in ViewBag.Suppliers)
                                    {
                                        if (item.SupplierID == Model.SupplierID)
                                        {
                                            <option value="@item.SupplierID" selected>@item.SupplierName</option>
                                        }
                                        else
                                        {
                                            <option value="@item.SupplierID">@item.SupplierName</option>
                                        }
                                    }
                                }
                            </select>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Đơn vị tính</label>
                        <div class="col-sm-9">
                            <input type="text" name="Unit" class="form-control" value="@Model.Unit" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Giá bán</label>
                        <div class="col-sm-9">
                            <input type="text" name="Price" class="form-control number-separator" value="@Model.Price.ToString("N0")" />
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Trạng thái</label>
                        <div class="col-sm-9">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" name="IsSelling" id="IsSelling" value="true" @(Model.IsSelling ? "checked" : "") />
                                <label class="form-check-label" for="IsSelling">Đang bán</label>
                            </div>
                        </div>
                    </div>

                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label">Ảnh</label>
                        <div class="col-sm-9">
                            <input type="file" name="uploadPhoto" class="form-control" accept="image/*"
                                   onchange="document.getElementById('imgPreview').src = window.URL.createObjectURL(this.files[0])" />
                            <div class="mt-2">
                                <img id="imgPreview" src="~/images/products/@(string.IsNullOrEmpty(Model.Photo) ? "nophoto.png" : Model.Photo)"
                                     class="img-thumbnail" style="max-height: 160px;" />
                            </div>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@if (Model.ProductID > 0)
{
    await Html.RenderPartialAsync("ListPhotos");
    await Html.RenderPartialAsync("ListAttributes");
}