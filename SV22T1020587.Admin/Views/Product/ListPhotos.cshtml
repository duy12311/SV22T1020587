@model SV22T1020587.Models.Catalog.Product
@{
    Layout = null;
    var photos = ViewBag.Photos as IEnumerable<SV22T1020587.Models.Catalog.ProductPhoto>;
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-info card-outline mt-4 shadow-sm">
            <div class="card-header">
                <div class="row align-items-center">
                    <div class="col">
                        <h6 id="photos" class="mb-0 fw-bold text-info">
                            <i class="bi bi-images me-2"></i> Thư viện ảnh
                        </h6>
                    </div>
                    <div class="col text-end">
                        <a class="btn btn-sm btn-primary" href="~/Product/Photo/@Model.ProductID?method=add">
                            <i class="bi bi-plus-circle me-1"></i> Thêm ảnh
                        </a>
                    </div>
                </div>
            </div>

            <div class="card-body p-1">
                @* --- THÔNG BÁO RIÊNG CHO PHẦN ẢNH --- *@
                @if (TempData["PhotoMessage"] != null)
                {
                    <div class="alert alert-info alert-dismissible fade show m-2 shadow-sm" role="alert">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        @TempData["PhotoMessage"]
                        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                    </div>
                }

                <div class="table-responsive">
                    <table class="table table-bordered table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th style="width:120px" class="text-center">Ảnh</th>
                                <th>Mô tả</th>
                                <th style="width:100px" class="text-center">Thứ tự</th>
                                <th style="width:120px" class="text-center">Hiển thị</th>
                                <th style="width:120px" class="text-center">Thao tác</th>
                            </tr>
                        </thead>
                        <tbody>
                            @if (photos != null && photos.Any())
                            {
                                foreach (var item in photos)
                                {
                                    <tr>
                                        <td class="text-center align-middle">
                                            <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                                                 class="img-thumbnail shadow-sm" style="max-height:60px; width:60px; object-fit:cover;"
                                                 alt="@item.Description" />
                                        </td>
                                        <td class="align-middle">
                                            <span class="text-dark fw-medium">@item.Description</span>
                                        </td>
                                        <td class="text-center align-middle">
                                            <span class="badge rounded-pill bg-light text-dark border">@item.DisplayOrder</span>
                                        </td>
                                        <td class="text-center align-middle">
                                            @if (item.IsHidden)
                                            {
                                                <span class="badge bg-secondary-subtle text-secondary border border-secondary">
                                                    <i class="bi bi-eye-slash me-1"></i> Đã ẩn
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-success-subtle text-success border border-success">
                                                    <i class="bi bi-eye me-1"></i> Hiển thị
                                                </span>
                                            }
                                        </td>
                                        <td class="text-center align-middle text-nowrap">
                                            <a class="btn btn-sm btn-outline-primary me-1"
                                               href="~/Product/Photo/@Model.ProductID?method=edit&photoId=@item.PhotoID"
                                               title="Chỉnh sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            <a class="btn btn-sm btn-outline-danger"
                                               href="~/Product/Photo/@Model.ProductID?method=delete&photoId=@item.PhotoID"
                                               onclick="return confirm('Bạn có chắc muốn xóa ảnh này khỏi thư viện?')"
                                               title="Xóa">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr>
                                    <td colspan="5" class="text-center text-muted p-4">
                                        <i class="bi bi-image fs-1 d-block mb-2 text-light"></i>
                                        Chưa có ảnh nào trong thư viện.
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Tự động ẩn thông báo ảnh sau 3 giây
    setTimeout(function () {
        $(".alert").fadeOut('slow');
    }, 3000);
</script>