@model SV22T1020587.Models.Common.PaginationSearchInput
@{
    ViewBag.Title = "Quản lý Loại hàng";
}

@section PageToolBar {
    <a href="~/Category/Create" class="btn btn-primary d-flex align-items-center ms-1">
        <i class="bi bi-plus-circle me-1"></i> Bổ sung
    </a>
}

@* HIỂN THỊ THÔNG BÁO TỪ CONTROLLER TRẢ VỀ *@
@if (TempData["Message"] != null)
{
    <div id="msg-alert" class="alert alert-success alert-dismissible fade show shadow-sm mb-3 border-start border-success border-4">
        <i class="bi bi-check-circle-fill me-2"></i> <strong>Thành công!</strong> @TempData["Message"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Category/Search" method="post" onsubmit="event.preventDefault(); doSearch(1);">
            <input type="hidden" name="PageSize" value="@Model.PageSize" />

            <div class="input-group">
                <input type="text" class="form-control" name="SearchValue"
                       value="@Model.SearchValue"
                       placeholder="Nhập tên loại hàng cần tìm..." autofocus />

                <button type="submit" class="btn btn-info d-flex align-items-center">
                    <i class="bi bi-search me-1"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>
</div>

<div id="searchResult"></div>

@section Scripts {
    <script>
        // Hàm AJAX tìm kiếm
        function doSearch(page) {
            var searchCondition = $("#formSearch").serializeArray();
            searchCondition.push({ name: "Page", value: page });

            $.ajax({
                url: $("#formSearch").prop("action"),
                type: $("#formSearch").prop("method"),
                data: searchCondition,
                success: function (data) {
                    $("#searchResult").html(data);
                },
                error: function () {
                    alert("Lỗi kết nối tới Server!");
                }
            });
        }

        $(document).ready(function () {
            // Tự động nạp dữ liệu bảng khi vừa mở trang
            doSearch(@Model.Page);

            // Tự động ẩn thông báo sau 3 giây
            setTimeout(function () {
                $("#msg-alert").fadeOut("slow");
            }, 3000);
        });
    </script>
}