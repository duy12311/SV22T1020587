@model SV22T1020587.Models.Catalog.Category
@{
    // Tiêu đề trang đã được gán từ Controller (ViewBag.Title)
}

@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary" onclick="return confirm('Xác nhận lưu dữ liệu?')">
        <i class="bi bi-save me-1"></i>
        Lưu dữ liệu
    </button>
    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-tags me-2 text-primary"></i>
                    Thông tin loại hàng
                </h5>
            </div>

            <div class="card-body">
                @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

                <form id="formEdit" action="~/Category/Save" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="CategoryID" value="@Model.CategoryID" />

                    <div class="mb-3">
                        <label class="form-label fw-bold">Tên loại hàng</label>
                        <input type="text"
                               class="form-control"
                               name="CategoryName"
                               value="@Model.CategoryName"
                               placeholder="Nhập tên loại hàng" autofocus />
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mô tả</label>
                        <textarea class="form-control"
                                  name="Description"
                                  rows="4"
                                  placeholder="Nhập mô tả loại hàng">@Model.Description</textarea>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>