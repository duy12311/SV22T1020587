@model SV22T1020587.Models.Common.PagedResult<SV22T1020587.Models.Catalog.Category>
@{
    Layout = null;
}

<div class="mb-2 text-muted">
    Danh sách này có <strong>@Model.RowCount</strong> loại hàng
</div>

<div class="card">
    <div class="card-body p-0">
        @if (Model.RowCount > 0)
        {
            <div class="table-responsive">
                <table class="table table-bordered table-hover mb-0">
                    <thead class="table-secondary">
                        <tr>
                            <th>Tên loại hàng</th>
                            <th>Mô tả</th>
                            <th class="text-center" style="width:100px;">Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.DataItems)
                        {
                            <tr>
                                <td class="align-middle">@item.CategoryName</td>
                                <td class="align-middle">@item.Description</td>
                                <td class="text-center text-nowrap">
                                    <a href="~/Category/Edit/@item.CategoryID" class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="~/Category/Delete/@item.CategoryID" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-warning text-center mb-0 m-3">
                <i class="bi bi-exclamation-triangle me-2"></i> Không tìm thấy dữ liệu phù hợp!
            </div>
        }
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center m-0">
                @for (int p = 1; p <= Model.PageCount; p++)
                {
                    if (p == Model.Page)
                    {
                        <li class="page-item active"><a class="page-link" href="javascript:;">@p</a></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:;" onclick="doSearch(@p)">@p</a>
                        </li>
                    }
                }
            </ul>
        </div>
    }
</div>