@model SV22T1020587.Models.Catalog.Category
@{
    ViewBag.Title = "Xóa loại hàng";
}

@section PageToolBar {
    <button type="submit" form="formDelete" class="btn btn-danger" onclick="return confirm('Hành động xóa không thể khôi phục. Bạn có chắc chắn muốn thực hiện?')">
        <i class="bi bi-trash me-1"></i>
        Xác nhận xóa
    </button>
    <a href="~/Category" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i>
        Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-danger card-outline shadow-sm">
            <div class="card-header">
                <h5 class="card-title mb-0 text-danger fw-bold">
                    <i class="bi bi-exclamation-triangle me-2"></i>
                    Xác nhận xóa loại hàng
                </h5>
            </div>

            <div class="card-body">
                @Html.ValidationSummary(false, "", new { @class = "text-danger mb-3" })

                @* HIỂN THỊ THÔNG BÁO LỖI (NẾU XÓA KHÔNG THÀNH CÔNG DO RÀNG BUỘC) *@
                @if (TempData["Error"] != null)
                {
                    <div class="alert alert-danger mb-3">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i> @TempData["Error"]
                    </div>
                }

                <form id="formDelete" action="~/Category/Delete" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="id" value="@Model.CategoryID" />

                    <div class="alert alert-warning d-flex align-items-center">
                        <i class="bi bi-info-circle me-2 fs-4"></i>
                        <div>Dữ liệu loại hàng sẽ bị xóa vĩnh viễn. Bạn có chắc chắn không?</div>
                    </div>

                    <dl class="row mb-0 px-3">
                        <dt class="col-sm-3 text-muted">Tên loại hàng:</dt>
                        <dd class="col-sm-9 fw-bold">@Model.CategoryName</dd>

                        <dt class="col-sm-3 text-muted">Mô tả:</dt>
                        <dd class="col-sm-9">
                            @(string.IsNullOrEmpty(Model.Description) ? "Không có mô tả" : Model.Description)
                        </dd>
                    </dl>
                </form>
            </div>
        </div>
    </div>
</div>