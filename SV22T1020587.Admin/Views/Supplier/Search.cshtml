@model SV22T1020587.Models.Common.PagedResult<SV22T1020587.Models.Partner.Supplier>
@{
    Layout = null; // Bắt buộc phải có Layout = null để không bị lặp thanh menu
}

<div class="mb-2 text-muted">
    Có tất cả <strong>@Model.RowCount</strong> nhà cung cấp trong <strong>@Model.PageCount</strong> trang
</div>

<div class="card">
    <div class="card-body p-1">
        <div class="table-responsive">
            <table class="table table-bordered table-hover mb-0">
                <thead class="table-secondary">
                    <tr>
                        <th>Tên nhà cung cấp</th>
                        <th>Tên giao dịch</th>
                        <th>Điện thoại</th>
                        <th>Email</th>
                        <th>Địa chỉ</th>
                        <th>Tỉnh/Thành</th>
                        <th style="width:100px" class="text-center">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model.DataItems != null)
                    {
                        foreach (var item in Model.DataItems)
                        {
                            <tr>
                                <td class="align-middle">@item.SupplierName</td>
                                <td class="align-middle">@item.ContactName</td>
                                <td class="align-middle">@item.Phone</td>
                                <td class="align-middle">@item.Email</td>
                                <td class="align-middle">@item.Address</td>
                                <td class="align-middle">@item.Province</td>
                                <td class="text-center align-middle text-nowrap">
                                    <a href="~/Supplier/Edit/@item.SupplierID" class="btn btn-sm btn-primary">
                                        <i class="bi bi-pencil"></i>
                                    </a>
                                    <a href="~/Supplier/Delete/@item.SupplierID" class="btn btn-sm btn-danger">
                                        <i class="bi bi-trash"></i>
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="card-footer">
            <ul class="pagination justify-content-center mb-0">
                @for (int p = 1; p <= Model.PageCount; p++)
                {
                    if (p == Model.Page)
                    {
                        <li class="page-item active"><a class="page-link" href="javascript:;">@p</a></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <a class="page-link" href="javascript:;" onclick="doSearch(@p)">@p</a>
                        </li>
                    }
                }
            </ul>
        </div>
    }
</div>