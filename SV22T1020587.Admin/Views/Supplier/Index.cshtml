@{
}

@if (TempData["SuccessMessage"] != null)
{
    <div id="successAlert" class="alert alert-success alert-dismissible fade show" role="alert">
        <i class="bi bi-check-circle-fill me-2"></i>
        <strong>Thành công!</strong> @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>

    <script>
        // Tự động ẩn thông báo sau 3 giây
        setTimeout(function () {
            var alertElement = document.getElementById('successAlert');
            if (alertElement) {
                var bsAlert = new bootstrap.Alert(alertElement);
                bsAlert.close();
            }
        }, 3000);
    </script>
}

<div class="box box-primary">
    <div class="box-body">
        <form id="formSearch" action="~/Supplier/Search" method="post" data-container="#searchResult">
            <div class="input-group">
                <input type="text" name="@nameof(PaginationSearchInput.SearchValue)"
                       class="form-control"
                       placeholder="Nhập tên nhà cung cấp cần tìm..."
                       value="@ViewBag.SearchValue" autofocus>

                <button class="btn btn-info" type="submit">
                    <i class="bi bi-search"></i> Tìm kiếm
                </button>

                <a href="~/Supplier/Create" class="btn btn-primary" style="margin-left:5px">
                    <i class="bi bi-plus-lg"></i> Bổ sung
                </a>
            </div>
        </form>

        <div id="searchResult" class="mt-3">
        </div>
    </div>
</div>

@section scripts {
    <script>
        function doSearch(page) {
            var searchCondition = $("#formSearch").serializeArray();
            searchCondition.push({ name: "Page", value: page });

            var action = $("#formSearch").prop("action");
            var method = $("#formSearch").prop("method");
            var container = $("#formSearch").data("container");

            $.ajax({
                url: action,
                type: method,
                data: searchCondition,
                success: function (data) {
                    $(container).html(data);
                }
            });
        }

        $(document).ready(function () {
            $("#formSearch").submit(function (e) {
                e.preventDefault();
                doSearch(1);
            });
            // Khởi chạy tìm kiếm lần đầu theo trang ở Session
            doSearch(@ViewBag.Page);
        });
    </script>
}