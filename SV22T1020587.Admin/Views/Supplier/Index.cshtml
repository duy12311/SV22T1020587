@{
    ViewBag.Title = "Quản lý Nhà cung cấp";
}

@section PageToolBar {
    <a href="~/Supplier/Create" class="btn btn-primary d-flex align-items-center ms-1">
        <i class="bi bi-plus-circle me-1"></i> Bổ sung
    </a>
}

<div class="card mb-3">
    <div class="card-body">
        <form id="formSearch" action="~/Supplier/Search" method="post" data-target="searchResult" onsubmit="paginationSearch(event, this, 1)">
            <div class="input-group">
                <input type="text" name="searchValue" class="form-control"
                       value="@ViewBag.SearchValue"
                       placeholder="Nhập tên nhà cung cấp..." autofocus />
                <button class="btn btn-info d-flex align-items-center" type="submit">
                    <i class="bi bi-search me-1"></i> Tìm kiếm
                </button>
            </div>
        </form>
    </div>
</div>

<div id="searchResult">
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // Tự động load trang đang xem trước đó nhờ biến ViewBag.Page
            paginationSearch(null, document.getElementById("formSearch"), @ViewBag.Page);
        });
    </script>
}