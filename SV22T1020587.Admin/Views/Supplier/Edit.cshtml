@model SV22T1020587.Models.Partner.Supplier
@{
}
@section PageToolBar {
    <button type="submit" form="formEdit" class="btn btn-primary">
        <i class="bi bi-save"></i> Lưu dữ liệu
    </button>
    <a href="~/Supplier" class="btn btn-secondary ms-1">
        <i class="bi bi-arrow-left"></i> Quay lại
    </a>
}

<div class="row justify-content-center">
    <div class="col-12">
        <div class="card card-primary card-outline">
            <div class="card-header">
                <h5 class="card-title mb-0">
                    <i class="bi bi-truck me-2"></i> @ViewBag.Title
                </h5>
            </div>

            <div class="card-body">
                <form id="formEdit" action="~/Supplier/Save" method="post">
                    <input type="hidden" name="SupplierID" value="@Model.SupplierID" />

                    <div class="mb-3">
                        <label class="form-label">Tên nhà cung cấp</label>
                        <input type="text" class="form-control" name="SupplierName" value="@Model.SupplierName" placeholder="Nhập tên nhà cung cấp" autofocus />
                        @Html.ValidationMessage(nameof(Model.SupplierName), new { @class = "text-danger" })
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tên giao dịch</label>
                        <input type="text" class="form-control" name="ContactName" value="@Model.ContactName" placeholder="Nhập tên giao dịch" />
                        @Html.ValidationMessage(nameof(Model.ContactName), new { @class = "text-danger" })
                    </div>

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label class="form-label">Điện thoại</label>
                            <input type="tel" class="form-control" name="Phone" value="@Model.Phone" placeholder="Nhập số điện thoại" />
                            @Html.ValidationMessage(nameof(Model.Phone), new { @class = "text-danger" })
                        </div>

                        <div class="col-md-6 mb-3">
                            <label class="form-label">Email</label>
                            <input type="email" class="form-control" name="Email" value="@Model.Email" placeholder="Nhập email" />
                            @Html.ValidationMessage(nameof(Model.Email), new { @class = "text-danger" })
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Địa chỉ</label>
                        <textarea class="form-control" name="Address" rows="3" placeholder="Nhập địa chỉ">@Model.Address</textarea>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Tỉnh / Thành</label>
                        <select class="form-select" name="Province">
                            @{
                                // Gọi dữ liệu động từ SelectListHelper
                                var provinces = await SV22T1020587.Admin.SelectListHelper.Provinces();
                                foreach (var item in provinces)
                                {
                                    if (item.Value == Model.Province)
                                    {
                                        <option value="@item.Value" selected>@item.Text</option>
                                    }
                                    else
                                    {
                                        <option value="@item.Value">@item.Text</option>
                                    }
                                }
                            }
                        </select>
                        @Html.ValidationMessage(nameof(Model.Province), new { @class = "text-danger" })
                    </div>

                    @Html.ValidationMessage("Error", new { @class = "text-danger" })
                </form>
            </div>
        </div>
    </div>
</div>