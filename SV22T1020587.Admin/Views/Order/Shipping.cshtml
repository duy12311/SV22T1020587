@model int
@{
    Layout = null;
    // Sử dụng dynamic để hiển thị danh sách mà không lo lỗi namespace
    var shippers = ViewBag.Shippers as IEnumerable<dynamic>;
}

<div class="modal-header text-bg-info">
    <strong class="modal-title">Chọn người giao hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>

<form action="~/Order/Shipping/@Model" method="post">
    @* Model ở đây là ID đơn hàng *@
    <input type="hidden" name="id" value="@Model" />

    <div class="modal-body">
        <div class="row">
            <div class="col-12">
                <label class="form-label mb-2">Người giao hàng</label>
                <select class="form-select" name="shipperID" required>
                    <option value="">-- Chọn người giao hàng ---</option>
                    @if (shippers != null)
                    {
                        foreach (var item in shippers)
                        {
                            @* Đảm bảo tên thuộc tính ShipperID và ShipperName khớp với DB *@
                            <option value="@item.ShipperID">@item.ShipperName</option>
                        }
                    }
                    else
                    {
                        <option value="" disabled>Lỗi: Không tải được danh sách Shipper</option>
                    }
                </select>
            </div>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">
            <i class="bi bi-bicycle"></i> Xác nhận Giao hàng
        </button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>