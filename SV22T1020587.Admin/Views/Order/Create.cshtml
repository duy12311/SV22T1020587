@using SV22T1020587.Models.Order
@model List<CartItem>
@{
    ViewBag.Title = "Lập đơn hàng";
    var cart = Model ?? new List<CartItem>();
}

<style>
    /* Ghim cột bên trái khi cuộn trang */
    .sticky-column {
        position: -webkit-sticky;
        position: sticky;
        top: 80px;
        max-height: calc(100vh - 100px);
        display: flex;
        flex-direction: column;
    }

    /* Giới hạn chiều cao và tạo cuộn cho vùng kết quả tìm kiếm */
    #searchResult {
        overflow-y: auto;
        flex-grow: 1;
        scrollbar-width: thin;
        padding-right: 5px;
    }

        #searchResult::-webkit-scrollbar {
            width: 6px;
        }

        #searchResult::-webkit-scrollbar-thumb {
            background-color: #cbd5e1;
            border-radius: 10px;
        }

    /* Cân đối các card */
    .card-order {
        border: none;
        box-shadow: 0 0.125rem 0.25rem rgba(0, 0, 0, 0.075);
        border-radius: 0.75rem;
    }

    .card-header {
        background-color: transparent;
        border-bottom: 1px solid rgba(0,0,0,0.05);
        padding: 1rem;
    }
</style>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card card-order card-outline card-primary sticky-column">
            <div class="card-header">
                <h5 class="mb-0 fw-bold text-primary"><i class="bi bi-search me-2"></i>Mặt hàng cần bán</h5>
            </div>
            <div class="card-body d-flex flex-column" style="min-height: 0;">
                <form id="frmSearchInput" action="~/Order/SearchProduct" method="get" class="mb-3">
                    <input type="hidden" name="PageSize" value="8" />
                    <div class="input-group">
                        <input type="text" class="form-control border-end-0" name="SearchValue"
                               placeholder="Tìm tên mặt hàng..." autofocus />
                        <button type="submit" class="btn btn-primary px-3">
                            <i class="bi bi-search"></i>
                        </button>
                    </div>
                </form>

                <div id="searchResult">
                    <div class="text-center text-muted py-5">
                        <i class="bi bi-upc-scan fs-1 d-block mb-2"></i>
                        <small>Kết quả tìm kiếm sẽ hiện ở đây</small>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card card-order card-outline card-success mb-4">
            <div class="card-header d-flex justify-content-between align-items-center">
                <h5 class="mb-0 fw-bold text-success"><i class="bi bi-cart-check me-2"></i>Danh sách hàng đã chọn</h5>
                <button type="button" id="btnClearCart" class="btn btn-sm btn-outline-danger border-0">
                    <i class="bi bi-trash"></i> Xóa tất cả
                </button>
            </div>
            <div class="card-body p-0" id="shoppingCart">
                @await Html.PartialAsync("ShowShoppingCart", cart)
            </div>
        </div>

        <div class="card card-order card-outline card-info">
            <div class="card-header">
                <h5 class="mb-0 fw-bold text-info"><i class="bi bi-person-badge me-2"></i>Thông tin khách hàng</h5>
            </div>
            <div class="card-body">
                <form id="frmOrderInit" method="post" action="~/Order/Init">
                    @* Loại đơn hàng *@
                    <div class="row mb-4">
                        <div class="col-md-12">
                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" name="orderType" id="orderTypeInStore" value="instore" checked>
                                <label class="btn btn-outline-primary" for="orderTypeInStore"><i class="bi bi-shop me-2"></i>Bán tại quầy</label>

                                <input type="radio" class="btn-check" name="orderType" id="orderTypeDelivery" value="delivery">
                                <label class="btn btn-outline-primary" for="orderTypeDelivery"><i class="bi bi-truck me-2"></i>Giao tận nơi</label>
                            </div>
                        </div>
                    </div>

                    @* Khách hàng *@
                    <div class="row mb-3">
                        <label class="col-sm-3 col-form-label fw-bold">Khách hàng:</label>
                        <div class="col-sm-9">
                            <select class="form-select mb-2" id="selCustomer" name="customerID">
                                <option value="0">-- Chọn khách hàng sẵn có --</option>
                                @if (ViewBag.Customers != null)
                                {
                                    foreach (var c in ViewBag.Customers)
                                    {
                                        <option value="@c.CustomerID"
                                                data-name="@c.CustomerName"
                                                data-phone="@c.Phone"
                                                data-province="@c.Province"
                                                data-address="@c.Address">
                                            @c.CustomerName - @c.Phone
                                        </option>
                                    }
                                }
                            </select>
                            <div class="row g-2">
                                <div class="col-md-7">
                                    <input type="text" id="customerName" name="customerName" class="form-control" placeholder="Tên khách lẻ..." />
                                </div>
                                <div class="col-md-5">
                                    <input type="text" id="customerPhone" name="customerPhone" class="form-control" placeholder="SĐT khách..." />
                                </div>
                            </div>
                        </div>
                    </div>

                    @* Khối giao hàng *@
                    <div id="deliveryBlock" style="border-top: 1px dashed #dee2e6; padding-top: 1rem; margin-top: 1rem;">
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label fw-bold">Tỉnh/thành:</label>
                            <div class="col-sm-9">
                                <select class="form-select select2" name="deliveryProvince" style="width: 100%">
                                    <option value="">-- Chọn Tỉnh/thành --</option>
                                    @if (ViewBag.Provinces != null)
                                    {
                                        foreach (var p in ViewBag.Provinces)
                                        {
                                            <option value="@p.ProvinceName">@p.ProvinceName</option>
                                        }
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="row mb-3">
                            <label class="col-sm-3 col-form-label fw-bold">Địa chỉ nhận:</label>
                            <div class="col-sm-9">
                                <textarea class="form-control" name="deliveryAddress" rows="2" placeholder="Số nhà, tên đường..."></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4">
                        <button type="submit" id="btnSubmitOrder" class="btn btn-primary w-100 py-2 fw-bold shadow-sm">
                            <i class="bi bi-check2-circle me-2"></i>XÁC NHẬN LẬP ĐƠN HÀNG
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@* Modal sửa số lượng *@
<div class="modal fade" id="editCartModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <form id="frmEditCart">
                <div class="modal-header bg-light">
                    <h6 class="modal-title fw-bold">Cập nhật số lượng</h6>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body p-4">
                    <input type="hidden" id="edit_productID" name="productID" />
                    <div class="input-group">
                        <span class="input-group-text bg-white"><i class="bi bi-plus-minus"></i></span>
                        <input type="number" id="edit_quantity" name="quantity" class="form-control text-center shadow-none" min="1" autofocus />
                    </div>
                </div>
                <div class="modal-footer border-0 pt-0">
                    <button type="button" class="btn btn-light px-3" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary px-4">Lưu lại</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        (function () {
            // Hàm tìm kiếm sản phẩm
            function doSearch(page) {
                var searchCondition = $("#frmSearchInput").serializeArray();
                searchCondition.push({ name: "Page", value: page });
                $.ajax({
                    url: $("#frmSearchInput").attr("action"),
                    type: "GET",
                    data: searchCondition,
                    success: function (data) {
                        $("#searchResult").html(data);
                    }
                });
            }
            window.doSearch = doSearch;

            // Hàm hiện giỏ hàng
            function showShoppingCart() {
                $.ajax({
                    url: '/Order/ShowShoppingCart',
                    type: 'GET',
                    success: function (data) { $('#shoppingCart').html(data); }
                });
            }
            window.showShoppingCart = showShoppingCart;

            // Chuyển đổi giao diện Giao hàng/Tại quầy
            function updateOrderTypeUI() {
                var type = $('input[name="orderType"]:checked').val();
                if (type === 'instore') {
                    $('#deliveryBlock').slideUp();
                } else {
                    $('#deliveryBlock').slideDown();
                }
            }

            $(function () {
                // Sự kiện khi chọn khách hàng từ danh sách
                $('#selCustomer').on('change', function () {
                    var opt = $(this).find(':selected');
                    $('#customerName').val(opt.data('name') || '');
                    $('#customerPhone').val(opt.data('phone') || '');
                    $('select[name="deliveryProvince"]').val(opt.data('province') || '').trigger('change');
                    $('textarea[name="deliveryAddress"]').val(opt.data('address') || '');
                });

                $('input[name="orderType"]').on('change', updateOrderTypeUI);

                doSearch(1);
                updateOrderTypeUI();

                $("#frmSearchInput").submit(function (e) { e.preventDefault(); doSearch(1); });

                // Thêm vào giỏ hàng AJAX
                $(document).on('submit', '.frmAddToCart', function (e) {
                    e.preventDefault();
                    var form = $(this);
                    $.ajax({
                        url: form.attr('action'),
                        type: 'POST',
                        data: form.serialize(),
                        success: function (data) {
                            if (data === "") showShoppingCart();
                            else {
                                Swal.fire({ icon: 'warning', text: data });
                            }
                        }
                    });
                });

                // XỬ LÝ LẬP ĐƠN HÀNG VỚI THÔNG BÁO THÀNH CÔNG
                $(document).on('submit', '#frmOrderInit', function (e) {
                    e.preventDefault();
                    var $form = $(this);
                    var orderType = $('input[name="orderType"]:checked').val();
                    var name = $('#customerName').val();

                    if (orderType === 'instore' && (!name || name.trim() === '')) {
                        $('#customerName').val('Khách lẻ');
                    }

                    var $btn = $('#btnSubmitOrder');
                    // Hiệu ứng Loading trên nút
                    $btn.prop('disabled', true).html('<span class="spinner-border spinner-border-sm me-2"></span> ĐANG XỬ LÝ...');

                    $.ajax({
                        url: $form.attr('action'),
                        type: 'POST',
                        data: $form.serialize(),
                        success: function (resp) {
                            if (resp.success) {
                                // Thông báo thành công
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Lập đơn thành công!',
                                    text: 'Hệ thống đang chuyển hướng đến chi tiết đơn hàng...',
                                    timer: 2000,
                                    showConfirmButton: false,
                                    allowOutsideClick: false
                                }).then(() => {
                                    window.location.href = '/Order/Detail/' + resp.orderID;
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Lỗi lập đơn',
                                    text: resp.message || 'Vui lòng kiểm tra lại thông tin.'
                                });
                                $btn.prop('disabled', false).html('<i class="bi bi-check2-circle me-2"></i>XÁC NHẬN LẬP ĐƠN HÀNG');
                            }
                        },
                        error: function () {
                            Swal.fire({
                                icon: 'error',
                                title: 'Lỗi kết nối',
                                text: 'Không thể kết nối tới máy chủ.'
                            });
                            $btn.prop('disabled', false).html('<i class="bi bi-check2-circle me-2"></i>XÁC NHẬN LẬP ĐƠN HÀNG');
                        }
                    });
                });

                $('#btnClearCart').on('click', function () {
                    Swal.fire({
                        title: 'Xác nhận xóa?',
                        text: "Bạn muốn xóa sạch tất cả mặt hàng trong giỏ?",
                        icon: 'warning',
                        showCancelButton: true,
                        confirmButtonColor: '#d33',
                        cancelButtonColor: '#3085d6',
                        confirmButtonText: 'Đúng, xóa sạch!',
                        cancelButtonText: 'Hủy'
                    }).then((result) => {
                        if (result.isConfirmed) {
                             $.get('/Order/ClearCart', function() { showShoppingCart(); });
                        }
                    });
                });

                // Sửa số lượng trong modal
                window.editCartItem = function (id, qty) {
                    $('#edit_productID').val(id);
                    $('#edit_quantity').val(qty);
                    var modal = new bootstrap.Modal(document.getElementById('editCartModal'));
                    modal.show();
                    setTimeout(() => $('#edit_quantity').focus().select(), 500);
                };

                $('#frmEditCart').submit(function(e) {
                    e.preventDefault();
                    $.post('/Order/UpdateCart', $(this).serialize(), function(data) {
                        if(data === "") {
                            bootstrap.Modal.getInstance(document.getElementById('editCartModal')).hide();
                            showShoppingCart();
                        } else alert(data);
                    });
                });

                window.removeFromCart = function(id) {
                    if(confirm("Xóa mặt hàng này khỏi giỏ?"))
                        $.get('/Order/RemoveFromCart/' + id, function(data) { if(data==="") showShoppingCart(); });
                };
            });
        })();
    </script>
}