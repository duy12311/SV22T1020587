@model int
@{
    Layout = null;
}
<div class="modal-header text-bg-danger">
    <strong class="modal-title">Xác nhận từ chối đơn hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>
<form action="~/Order/Reject" method="post">
    <input type="hidden" name="id" value="@Model" />
    <div class="modal-body">
        <div class="alert alert-danger d-flex align-items-center mb-3">
            <i class="bi bi-exclamation-triangle me-2 fs-4"></i>
            <div>
                Bạn có thực sự muốn <strong>từ chối</strong> đơn hàng này hay không? Việc từ chối sẽ không thể hoàn tác.
            </div>
        </div>

        <div class="mb-3">
            <label class="form-label">Lý do từ chối (Tùy chọn):</label>
            <textarea class="form-control" name="reason" rows="3" placeholder="Ví dụ: Hết hàng, sai thông tin..."></textarea>
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-danger"><i class="bi bi-check-circle"></i> Từ chối đơn hàng</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy bỏ</button>
    </div>
</form>