@model SV22T1020587.Models.Common.PagedResult<SV22T1020587.Models.Catalog.Product>
@using SV22T1020587.BusinessLayers
@{
    Layout = null;
}

@if (Model.DataItems != null && Model.DataItems.Count > 0)
{
    <div class="list-group list-group-flush">
        @foreach (var item in Model.DataItems)
        {
            <form action="~/Order/AddToCart" method="post" class="frmAddToCart list-group-item p-2 border-bottom">
                @* Vẫn giữ hidden SalePrice để gửi giá cố định về Server *@
                <input type="hidden" name="ProductID" value="@item.ProductID" />
                <input type="hidden" name="ProductName" value="@item.ProductName" />
                <input type="hidden" name="Photo" value="@item.Photo" />
                <input type="hidden" name="Unit" value="@item.Unit" />
                <input type="hidden" name="SalePrice" value="@item.Price" />

                <div class="row g-2 align-items-center">
                    <div class="col-auto">
                        <img src="~/images/products/@(string.IsNullOrEmpty(item.Photo) ? "nophoto.png" : item.Photo)"
                             class="rounded border"
                             style="width:40px; height:40px; object-fit:cover;"
                             onerror="this.src='/images/products/nophoto.png'" />
                    </div>

                    <div class="col">
                        <div class="fw-bold text-truncate" title="@item.ProductName" style="font-size:0.85rem; max-width:200px;">
                            @item.ProductName
                        </div>
                        <div class="text-danger small fw-bold">
                            @item.Price.ToString("N0") <span class="text-muted" style="font-size:0.7rem;">đ</span>
                        </div>
                    </div>

                    <div class="col-auto">
                        <div class="d-flex align-items-center">
                            <input type="number" name="Quantity" min="1" value="1"
                                   class="form-control form-control-sm text-center me-2"
                                   style="width: 55px; font-weight: bold;" />

                            <button type="submit" class="btn btn-primary btn-sm px-3">
                                <i class="bi bi-plus-lg"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        }
    </div>

    @if (Model.PageCount > 1)
    {
        <div class="d-flex justify-content-between align-items-center mt-2 px-2">
            <span class="text-muted" style="font-size:0.75rem;">Tổng: <strong>@Model.RowCount</strong></span>
            <ul class="pagination pagination-sm mb-0">
                <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" onclick="doSearch(@(Model.Page - 1))">«</a>
                </li>
                @for (int p = 1; p <= Model.PageCount; p++)
                {
                    if (p == Model.Page || (p >= Model.Page - 1 && p <= Model.Page + 1))
                    {
                        <li class="page-item @(p == Model.Page ? "active" : "")">
                            <a class="page-link" href="javascript:;" onclick="doSearch(@p)">@p</a>
                        </li>
                    }
                }
                <li class="page-item @(Model.Page >= Model.PageCount ? "disabled" : "")">
                    <a class="page-link" href="javascript:;" onclick="doSearch(@(Model.Page + 1))">»</a>
                </li>
            </ul>
        </div>
    }
}