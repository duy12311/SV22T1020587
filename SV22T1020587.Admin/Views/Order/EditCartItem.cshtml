@model SV22T1020587.Models.Sales.OrderDetailViewInfo
@{
    Layout = null;
}
<div class="modal-header">
    <strong class="modal-title">Cập nhật chi tiết đơn hàng</strong>
    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
</div>
<form action="~/Order/UpdateCartItem" method="post">
    <input type="hidden" name="OrderID" value="@Model.OrderID" />
    <input type="hidden" name="ProductID" value="@Model.ProductID" />

    <div class="modal-body">
        <div class="container-fluid">
            <div class="row">
                <div class="col-md-8">
                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-4 col-form-label fw-semibold">Mặt hàng</label>
                        <div class="col-sm-8">
                            <input type="text" class="form-control-plaintext fw-bold" value="@Model.ProductName" readonly>
                        </div>
                    </div>
                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-4 col-form-label fw-semibold">Số lượng</label>
                        <div class="col-sm-5">
                            <input type="number" class="form-control text-end" name="Quantity" min="1" value="@Model.Quantity">
                        </div>
                    </div>
                    <div class="row mb-3 align-items-center">
                        <label class="col-sm-4 col-form-label fw-semibold">Đơn giá</label>
                        <div class="col-sm-5">
                            <input type="text" class="form-control text-end number-separator" name="SalePrice" value="@Model.SalePrice">
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <button type="submit" class="btn btn-primary">Cập nhật</button>
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Đóng</button>
    </div>
</form>