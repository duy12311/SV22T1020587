@model SV22T1020587.Models.Sales.OrderViewInfo
@{
    ViewBag.Title = "Chi tiết đơn hàng";
}

@if (Model == null)
{
    <div class="container-fluid">
        <div class="alert alert-danger mt-3">
            <h5><i class="icon fas fa-ban"></i> Lỗi!</h5>
            Không tìm thấy thông tin đơn hàng yêu cầu.
        </div>
        <a href="~/Order" class="btn btn-default">Quay lại danh sách</a>
    </div>
}
else
{
    @section PageToolBar {
        <div class="btn-group">
            @if ((int)Model.Status == 1 || (int)Model.Status == 2 || (int)Model.Status == 3)
            {
                <button type="button" class="btn btn-primary dropdown-toggle" data-bs-toggle="dropdown">
                    <i class="bi bi-gear me-1"></i> Xử lý đơn hàng
                </button>
                <ul class="dropdown-menu shadow">
                    @if ((int)Model.Status == 1)
                    {
                        <li>
                            <a class="dropdown-item btn-accept" href="~/Order/Accept/@Model.OrderID">
                                <i class="bi bi-check-circle text-success me-2"></i>Duyệt đơn hàng
                            </a>
                        </li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger btn-confirm-action" href="~/Order/Reject/@Model.OrderID" data-msg="Xác nhận từ chối đơn hàng này?">Từ chối đơn hàng</a></li>
                        <li><a class="dropdown-item text-danger btn-confirm-action" href="~/Order/Cancel/@Model.OrderID" data-msg="Xác nhận hủy đơn hàng này?">Hủy đơn hàng</a></li>
                    }
                    else if ((int)Model.Status == 2)
                    {
                        <li><a class="dropdown-item btn-modal" href="~/Order/Shipping/@Model.OrderID"><i class="bi bi-truck me-2"></i>Chuyển giao hàng</a></li>
                        <li><hr class="dropdown-divider"></li>
                        <li><a class="dropdown-item text-danger btn-confirm-action" href="~/Order/Reject/@Model.OrderID" data-msg="Xác nhận từ chối đơn hàng này?">Từ chối đơn hàng</a></li>
                        <li><a class="dropdown-item text-danger btn-confirm-action" href="~/Order/Cancel/@Model.OrderID" data-msg="Xác nhận hủy đơn hàng này?">Hủy đơn hàng</a></li>
                    }
                    else if ((int)Model.Status == 3)
                    {
                        <li><a class="dropdown-item btn-confirm-action" href="~/Order/Finish/@Model.OrderID" data-msg="Xác nhận đơn hàng đã hoàn tất?"><i class="bi bi-flag me-2"></i>Xác nhận hoàn tất</a></li>
                        <li><a class="dropdown-item text-danger btn-confirm-action" href="~/Order/Cancel/@Model.OrderID" data-msg="Xác nhận hủy đơn hàng này?">Hủy đơn hàng</a></li>
                    }
                </ul>
            }
        </div>

        @if ((int)Model.Status == -1 || (int)Model.Status == -2 || (int)Model.Status == 4)
        {
            <a href="~/Order/Delete/@Model.OrderID" class="btn btn-danger ms-1 btn-confirm-action" data-msg="Bạn có chắc chắn muốn xóa đơn hàng này không?">
                <i class="bi bi-trash"></i> Xóa đơn hàng
            </a>
        }
        <a href="~/Order" class="btn btn-secondary ms-1">Quay lại</a>
    }

    <div class="card card-primary card-outline shadow-sm">
        <div class="card-body">
            <div class="row mb-3">
                <div class="col-md-6 border-end">
                    <h5 class="text-primary fw-bold mb-3"><i class="bi bi-person-badge"></i> Thông tin khách hàng</h5>
                    <table class="table table-sm table-borderless">
                        <tr><th style="width: 150px">Khách hàng:</th><td class="fw-bold">@Model.CustomerName</td></tr>
                        <tr><th>Tên giao dịch:</th><td>@Model.CustomerContactName</td></tr>
                        <tr><th>Điện thoại:</th><td>@Model.CustomerPhone</td></tr>
                        <tr><th>Email:</th><td>@Model.CustomerEmail</td></tr>
                        <tr><th>Địa chỉ nhận:</th><td>@Model.DeliveryAddress</td></tr>
                        <tr><th>Tỉnh/Thành:</th><td>@Model.DeliveryProvince</td></tr>
                    </table>
                </div>

                <div class="col-md-6">
                    <h5 class="text-success fw-bold mb-3"><i class="bi bi-truck"></i> Thông tin giao hàng</h5>
                    <table class="table table-sm table-borderless">
                        <tr><th style="width: 150px">Người giao hàng:</th><td>@(string.IsNullOrEmpty(Model.ShipperName) ? "(Chưa có)" : Model.ShipperName)</td></tr>
                        <tr><th>Điện thoại:</th><td>@Model.ShipperPhone</td></tr>
                        <tr><th>Nhân viên phụ trách:</th><td>@Model.EmployeeName</td></tr>
                        <tr><th>Trạng thái:</th><td class="badge bg-info text-dark" style="font-size: 0.9rem;">@Model.StatusDescription</td></tr>
                    </table>
                </div>
            </div>

            <h5 class="text-info mt-4 fw-bold"><i class="bi bi-cart3"></i> Chi tiết các mặt hàng</h5>
            <div class="table-responsive">
                <table class="table table-bordered table-striped table-hover mt-2">
                    <thead class="table-light text-center">
                        <tr>
                            <th>STT</th>
                            <th>Tên mặt hàng</th>
                            <th>Số lượng</th>
                            <th class="text-end">Giá bán</th>
                            <th class="text-end">Thành tiền</th>
                            <th>Thao tác</th>
                        </tr>
                    </thead>
                    <tbody>
                        @if (ViewBag.Details != null)
                        {
                            int stt = 1;
                            decimal total = 0;
                            foreach (var item in ViewBag.Details)
                            {
                                decimal thanhTien = item.Quantity * item.SalePrice;
                                total += thanhTien;
                                <tr>
                                    <td class="text-center">@(stt++)</td>
                                    <td>@item.ProductName</td>
                                    <td class="text-center">@item.Quantity</td>
                                    <td class="text-end">@item.SalePrice.ToString("N0")</td>
                                    <td class="text-end fw-bold">@thanhTien.ToString("N0")</td>
                                    <td class="text-center">
                                        @if ((int)Model.Status == 1)
                                        {
                                            <a href="~/Order/EditDetail/@Model.OrderID?productId=@item.ProductID" class="btn btn-sm btn-outline-primary btn-modal" title="Sửa">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                            @* Sửa lỗi xóa mặt hàng bằng cách dùng class riêng và chặn sự kiện mặc định *@
                                            <a href="~/Order/DeleteDetail/@Model.OrderID?productId=@item.ProductID"
                                               class="btn btn-sm btn-outline-danger btn-delete-detail"
                                               data-msg="Xác nhận xóa mặt hàng [@item.ProductName] khỏi đơn hàng?">
                                                <i class="bi bi-trash"></i>
                                            </a>
                                        }
                                    </td>
                                </tr>
                            }
                            <tr class="table-warning">
                                <td colspan="4" class="text-end fw-bold">TỔNG CỘNG:</td>
                                <td class="text-end text-danger fw-bold fs-5">@total.ToString("N0") VNĐ</td>
                                <td></td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div id="modal-container" class="modal fade" role="dialog" tabindex="-1">
        <div class="modal-dialog modal-lg">
            <div class="modal-content" id="modal-content"></div>
        </div>
    </div>
}

@section scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function () {
            // 1. Mở Modal chung
            $(".btn-modal").click(function (e) {
                e.preventDefault();
                $.get($(this).attr("href"), function (data) {
                    $("#modal-content").html(data);
                    $("#modal-container").modal("show");
                });
            });

            // 2. Luồng Duyệt đơn hàng
            $(".btn-accept").click(function (e) {
                e.preventDefault();
                let link = $(this).attr("href");

                Swal.fire({
                    title: 'Xác nhận duyệt?',
                    text: "Đơn hàng sẽ được chuyển sang trạng thái chờ xử lý.",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonText: 'Đồng ý duyệt'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.get(link, function (data) {
                            Swal.fire({
                                icon: 'success',
                                title: 'Duyệt thành công!',
                                text: 'Vui lòng thực hiện bước tiếp theo.',
                                timer: 1200,
                                showConfirmButton: false
                            }).then(() => {
                                $("#modal-content").html(data);
                                $("#modal-container").modal("show");
                            });
                        }).fail(() => location.reload());
                    }
                });
            });

            // 3. Xử lý xóa mặt hàng (Sửa lỗi xóa bị nhảy trang hoặc không chạy)
            $(".btn-delete-detail").click(function (e) {
                e.preventDefault();
                let link = $(this).attr("href");
                let msg = $(this).data("msg");

                Swal.fire({
                    title: 'Xác nhận xóa?',
                    text: msg,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonColor: '#d33',
                    confirmButtonText: 'Xóa ngay'
                }).then((result) => {
                    if (result.isConfirmed) {
                        $.ajax({
                            url: link,
                            type: "GET",
                            success: function () {
                                Swal.fire({ icon: 'success', title: 'Đã xóa!', timer: 1000, showConfirmButton: false })
                                .then(() => location.reload());
                            },
                            error: () => Swal.fire('Lỗi', 'Không thể xóa mặt hàng.', 'error')
                        });
                    }
                });
            });

            // 4. Submit Form trong Modal (Giao hàng / Lập hóa đơn)
            $(document).on("submit", "#modal-content form", function (e) {
                e.preventDefault();
                let form = $(this);
                let url = form.attr("action");
                let isShipping = url.toLowerCase().includes("shipping");

                $.ajax({
                    url: url,
                    type: "POST",
                    data: form.serialize(),
                    success: function () {
                        Swal.fire({
                            icon: 'success',
                            title: isShipping ? 'Chuyển giao hàng thành công!' : 'Lập hóa đơn thành công!',
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            $("#modal-container").modal("hide");
                            location.reload();
                        });
                    },
                    error: () => Swal.fire('Lỗi', 'Thao tác thất bại.', 'error')
                });
            });

            // 5. Các nút xác nhận khác (Hủy, Từ chối, Xóa đơn, Hoàn tất)
            $(".btn-confirm-action").click(function (e) {
                e.preventDefault();
                let link = $(this).attr("href");
                let msg = $(this).data("msg");

                Swal.fire({
                    title: 'Xác nhận',
                    text: msg,
                    icon: 'warning',
                    showCancelButton: true,
                    confirmButtonText: 'Đồng ý'
                }).then((result) => {
                    if (result.isConfirmed) window.location.href = link;
                });
            });
        });
    </script>
}