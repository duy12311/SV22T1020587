@{
    ViewBag.Title = "Thay đổi mật khẩu";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-12">
        <form action="~/Account/ChangePassword" method="post">
            @Html.AntiForgeryToken()
            <div class="card card-warning card-outline shadow-sm">
                <div class="card-header">
                    <h3 class="card-title fw-bold">
                        <i class="bi bi-shield-lock-fill"></i> Thay đổi mật khẩu
                    </h3>
                </div>
                <div class="card-body">

                    @* Hiển thị thông báo LỖI *@
                    @if (!string.IsNullOrEmpty(ViewBag.Error))
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill"></i> @ViewBag.Error
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    @* Hiển thị thông báo THÀNH CÔNG *@
                    @if (!string.IsNullOrEmpty(ViewBag.Success))
                    {
                        <div class="alert alert-success alert-dismissible fade show" role="alert">
                            <i class="bi bi-check-circle-fill"></i> @ViewBag.Success
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu cũ</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-lock-fill"></i></span>
                            <input type="password" name="oldPassword" class="form-control" placeholder="Nhập mật khẩu hiện tại" autofocus required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Mật khẩu mới</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-key-fill"></i></span>
                            <input type="password" name="newPassword" class="form-control" placeholder="Nhập mật khẩu mới" required>
                        </div>
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold">Xác nhận lại mật khẩu</label>
                        <div class="input-group">
                            <span class="input-group-text"><i class="bi bi-check-all"></i></span>
                            <input type="password" name="confirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới" required>
                        </div>
                    </div>
                </div>
                <div class="card-footer text-end">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-save"></i> Đổi mật khẩu
                    </button>
                    <a href="~/" class="btn btn-secondary me-2">
                        <i class="bi bi-arrow-left"></i> Quay lại
                    </a>
                </div>
            </div>
        </form>
    </div>
</div>

@section scripts {
    <script>
        // Tự động ẩn thông báo sau 5 giây để màn hình gọn gàng
        $(document).ready(function () {
            setTimeout(function () {
                $(".alert").fadeOut('slow');
            }, 5000);
        });
    </script>
}