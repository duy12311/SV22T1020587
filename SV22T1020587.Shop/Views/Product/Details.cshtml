@model SV22T1020587.Models.Catalog.Product
@{
    ViewBag.Title = @Model?.ProductName ?? "Chi tiết sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var photos = ViewBag.Photos as IEnumerable<SV22T1020587.Models.Catalog.ProductPhoto> ?? Enumerable.Empty<SV22T1020587.Models.Catalog.ProductPhoto>();
    var attributes = ViewBag.Attributes as IEnumerable<SV22T1020587.Models.Catalog.ProductAttribute> ?? Enumerable.Empty<SV22T1020587.Models.Catalog.ProductAttribute>();

    string mainImage = photos.FirstOrDefault()?.Photo ?? Model.Photo ?? "/images/no-image.png";
}
<div class="mb-3">
    <a class="btn btn-outline-secondary btn-sm" asp-controller="Product" asp-action="Index">← Trở về</a>
    <noscript><a href="~/Product" class="btn btn-outline-secondary btn-sm">← Trở về</a></noscript>
</div>

<div class="row g-4">
    <div class="col-lg-6">
        <div class="card">
            <img id="mainProductImage" src="@mainImage" class="img-fluid" alt="@Model.ProductName" style="object-fit:cover;max-height:520px;width:100%;">
        </div>

        @if (photos.Any())
        {
            <div class="mt-3 d-flex gap-2 flex-wrap">
                @foreach (var p in photos)
                {
                    <button type="button" class="btn btn-outline-secondary p-0" style="width:90px;height:90px;overflow:hidden;" data-photo="@p.Photo" title="@p.Description">
                        <img src="@(string.IsNullOrEmpty(p.Photo) ? "/images/no-image.png" : p.Photo)" alt="@p.Description" style="width:100%;height:100%;object-fit:cover;" />
                    </button>
                }
            </div>
        }
    </div>

    <div class="col-lg-6">
        <div class="card p-4 shadow-sm">
            <h3 class="fw-bold">@Model.ProductName</h3>
            <p class="text-muted mb-1">Mã hàng: <span class="text-secondary">@Model.ProductID</span></p>
            <h4 class="text-danger fw-bold">@String.Format("{0:N0}", Model.Price) VND</h4>

            <hr />

            <h6 class="fw-semibold">Mô tả</h6>
            <p class="text-muted">@Model.ProductDescription</p>

            @if (attributes.Any())
            {
                <hr />
                <h6 class="fw-semibold">Thông số</h6>
                <table class="table table-sm">
                    <tbody>
                        @foreach (var a in attributes)
                        {
                            <tr>
                                <th class="w-50 align-top" scope="row">@a.AttributeName</th>
                                <td>@a.AttributeValue</td>
                            </tr>
                        }
                    </tbody>
                </table>
            }

            <div class="d-flex align-items-center gap-3 mt-3">
                <div class="input-group" style="width:150px;">
                    <button class="btn btn-outline-secondary" type="button" id="decQty">-</button>
                    <input type="number" id="qtyInput" class="form-control text-center" value="1" min="1" />
                    <button class="btn btn-outline-secondary" type="button" id="incQty">+</button>
                </div>

                <form id="frmAddToCart" method="post" action="~/Cart/Add" class="ms-2">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="ProductID" value="@Model.ProductID" />
                    <input type="hidden" name="ProductName" value="@Model.ProductName" />
                    <input type="hidden" name="Photo" id="formPhoto" value="@mainImage" />
                    <input type="hidden" name="SalePrice" value="@Model.Price" />
                    <input type="hidden" name="Quantity" id="formQuantity" value="1" />
                    <button type="submit" class="btn btn-primary btn-lg btn-rounded" id="btnAddToCart"><i class="fa-solid fa-cart-plus me-2"></i>Thêm vào giỏ</button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function(){
          const dec = document.getElementById('decQty'), inc = document.getElementById('incQty');
          const qty = document.getElementById('qtyInput'), formQty = document.getElementById('formQuantity');
          dec?.addEventListener('click', ()=> { let v = Math.max(1, parseInt(qty.value||'1')-1); qty.value = v; formQty.value = v; });
          inc?.addEventListener('click', ()=> { let v = Math.max(1, parseInt(qty.value||'1')+1); qty.value = v; formQty.value = v; });
          qty?.addEventListener('change', ()=> { let v = Math.max(1, parseInt(qty.value||'1')); qty.value = v; formQty.value = v; });

          document.querySelectorAll('[data-photo]').forEach(function(btn){
              btn.addEventListener('click', function(e){
                  e.preventDefault();
                  const photo = btn.getAttribute('data-photo');
                  if(photo){
                      const main = document.getElementById('mainProductImage');
                      const formPhoto = document.getElementById('formPhoto');
                      if(main) main.src = photo;
                      if(formPhoto) formPhoto.value = photo;
                  }
              });
          });

          const form = document.getElementById('frmAddToCart');
          if (form) {
              form.addEventListener('submit', async function (e) {
                  e.preventDefault();

                  const btn = document.getElementById('btnAddToCart');
                  btn.disabled = true;

                  const fd = new FormData(form);

                  try {
                      const response = await fetch(form.action, {
                          method: 'POST',
                          body: fd,
                          credentials: 'same-origin'
                      });

                      let data = null;
                      const contentType = response.headers.get('content-type') || '';

                      if (contentType.indexOf('application/json') !== -1) {
                          data = await response.json();
                      } else {
                          const txt = await response.text();
                          try {
                              data = JSON.parse(txt);
                          } catch {
                              const m = txt.match(/\{[\s\S]*\}/);
                              if (m) {
                                  try { data = JSON.parse(m[0]); } catch { data = null; }
                              } else {
                                  data = null;
                              }
                          }
                      }

                      btn.disabled = false;

                      if (data && data.requiresLogin) {
                          const loginUrl = data.loginUrl || '/Account/Login';
                          const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
                          const sep = loginUrl.indexOf('?') >= 0 ? '&' : '?';
                          window.location.href = loginUrl + sep + 'ReturnUrl=' + returnUrl;
                          return;
                      }

                      if (response.ok && data && (data.success === true || data.success === "true")) {
                          if (data && typeof data.count !== 'undefined') {
                              try { window.setCartCount(Number(data.count)); } catch {}
                          } else {
                              try {
                                  const desktopBadge = document.getElementById('cartCount');
                                  const mobileBadge = document.getElementById('cartCountMobile');
                                  const added = parseInt(formQty.value || '1', 10) || 1;
                                  const updateBadge = (el) => {
                                      if (!el) return;
                                      const cur = parseInt(el.textContent || '0', 10) || 0;
                                      el.textContent = cur + added;
                                  };
                                  updateBadge(desktopBadge);
                                  updateBadge(mobileBadge);
                                  try {
                                      const curClient = parseInt(sessionStorage.getItem('lite_cart_count') || '0', 10) || 0;
                                      sessionStorage.setItem('lite_cart_count', (curClient + added).toString());
                                  } catch {}
                              } catch {}
                          }

                          const prev = document.getElementById('btnAddToCart');
                          prev.innerHTML = '<i class="fa-solid fa-cart-plus me-2"></i>Đã thêm';
                          setTimeout(()=> prev.innerHTML = '<i class="fa-solid fa-cart-plus me-2"></i>Thêm vào giỏ', 1200);
                      } else {
                          const msg = (data && data.message) ? data.message : 'Không thể thêm vào giỏ.';
                          alert(msg);
                      }
                  } catch (err) {
                      console.error(err);
                      btn.disabled = false;
                      alert('Lỗi mạng khi thêm vào giỏ.');
                  }
              });
          }
        })();
    </script>
}