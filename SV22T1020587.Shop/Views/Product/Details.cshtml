@model SV22T1020587.Models.Catalog.Product
@{
    ViewBag.Title = @Model?.ProductName ?? "Chi tiết sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var photos = ViewBag.Photos as IEnumerable<SV22T1020587.Models.Catalog.ProductPhoto> ?? Enumerable.Empty<SV22T1020587.Models.Catalog.ProductPhoto>();
    var attributes = ViewBag.Attributes as IEnumerable<SV22T1020587.Models.Catalog.ProductAttribute> ?? Enumerable.Empty<SV22T1020587.Models.Catalog.ProductAttribute>();

    string mainImage = photos.FirstOrDefault()?.Photo ?? Model.Photo ?? "/images/no-image.png";
}

<div class="container mb-4 mt-3">
    <div class="mb-3">
        <a class="brutal-border border-2 bg-white text-dark px-2 py-1 fw-bold text-decoration-none hover-invert d-inline-block" style="font-size: 0.85rem;" asp-controller="Product" asp-action="Index">
            <i class="fa-solid fa-arrow-left me-1"></i> TRỞ VỀ
        </a>
        <noscript><a href="~/Product" class="brutal-border border-2 bg-white text-dark px-2 py-1 fw-bold text-decoration-none hover-invert d-inline-block" style="font-size: 0.85rem;"><i class="fa-solid fa-arrow-left me-1"></i> TRỞ VỀ</a></noscript>
    </div>

    <div class="row g-3">
        <div class="col-md-5 col-lg-4">
            <div class="brutal-border border-3 bg-white p-1 mb-2" style="box-shadow: 4px 4px 0px #000;">
                <img id="mainProductImage" src="@mainImage" class="img-fluid w-100" alt="@Model.ProductName" style="object-fit:contain; height:300px; border: 2px solid #000; background-color: #f8f9fa;">
            </div>

            @if (photos.Any())
            {
                <div class="d-flex gap-2 flex-wrap">
                    @foreach (var p in photos)
                    {
                        <button type="button" class="btn p-0 brutal-border border-2 hover-invert" style="width:60px;height:60px;overflow:hidden; border-radius: 0;" data-photo="@p.Photo" title="@p.Description">
                            <img src="@(string.IsNullOrEmpty(p.Photo) ? "/images/no-image.png" : p.Photo)" alt="@p.Description" style="width:100%;height:100%;object-fit:cover; mix-blend-mode: multiply;" />
                        </button>
                    }
                </div>
            }
        </div>

        <div class="col-md-7 col-lg-8">
            <div class="brutal-border border-3 bg-white p-3 p-md-4 h-100" style="box-shadow: 4px 4px 0px #000;">

                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                    <h2 class="fw-black text-uppercase m-0 fs-3" style="letter-spacing: -0.5px; line-height: 1.2;">
                        @Model.ProductName
                    </h2>
                    <span class="bg-dark text-white px-2 py-1 fw-bold brutal-border border-2 text-nowrap" style="font-size: 0.8rem;">
                        MÃ: @Model.ProductID
                    </span>
                </div>

                <h3 class="text-primary fw-black mb-3 fs-2" style="text-shadow: 1px 1px 0 #000;">
                    @String.Format("{0:N0}", Model.Price) đ
                </h3>

                <div class="brutal-border border-2 bg-light p-2 mb-4" style="background-image: radial-gradient(#ddd 1px, transparent 1px); background-size: 10px 10px;">
                    <div class="d-flex flex-column flex-sm-row gap-2">

                        <div class="d-flex brutal-border border-2 bg-white flex-shrink-0" style="width: 120px; height: 45px;">
                            <button class="btn btn-light border-0 rounded-0 fw-black px-2 hover-invert w-100" type="button" id="decQty">-</button>
                            <input type="number" id="qtyInput" class="form-control border-0 border-start border-end border-dark border-2 rounded-0 text-center fw-black shadow-none px-1" value="1" min="1" />
                            <button class="btn btn-light border-0 rounded-0 fw-black px-2 hover-invert w-100" type="button" id="incQty">+</button>
                        </div>

                        <form id="frmAddToCart" method="post" action="~/Cart/Add" class="flex-grow-1 m-0" style="height: 45px;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="ProductID" value="@Model.ProductID" />
                            <input type="hidden" name="ProductName" value="@Model.ProductName" />
                            <input type="hidden" name="Photo" id="formPhoto" value="@mainImage" />
                            <input type="hidden" name="SalePrice" value="@Model.Price" />
                            <input type="hidden" name="Quantity" id="formQuantity" value="1" />

                            <button type="submit" class="brutal-btn w-100 h-100 fw-black text-uppercase d-flex justify-content-center align-items-center m-0" id="btnAddToCart">
                                <i class="fa-solid fa-cart-plus me-2"></i> THÊM VÀO GIỎ
                            </button>
                        </form>
                    </div>
                </div>

                <h6 class="fw-black text-uppercase mb-1"><i class="fa-solid fa-circle-info me-2"></i>Mô tả</h6>
                <p class="text-dark mb-3" style="font-size: 0.95rem; line-height: 1.5;">
                    @Model.ProductDescription
                </p>

                @if (attributes.Any())
                {
                    <h6 class="fw-black text-uppercase mt-3 mb-1"><i class="fa-solid fa-list-ul me-2"></i>Thông số</h6>
                    <div class="table-responsive brutal-border border-2">
                        <table class="table table-sm table-bordered border-dark m-0 table-striped" style="font-size: 0.9rem;">
                            <tbody>
                                @foreach (var a in attributes)
                                {
                                    <tr>
                                        <th class="w-25 align-middle bg-light text-uppercase border-dark" scope="row">@a.AttributeName</th>
                                        <td class="border-dark align-middle">@a.AttributeValue</td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }

            </div>
        </div>
    </div>
</div>

<style>
    .brutal-btn {
        background-color: var(--b-primary, #0d6efd);
        color: #fff;
        border: 2px solid #000;
        box-shadow: 3px 3px 0px #000;
        transition: all 0.15s ease-in-out;
        text-decoration: none;
        display: inline-block;
        border-radius: 0;
    }

        .brutal-btn:hover:not(:disabled) {
            transform: translate(2px, 2px);
            box-shadow: 1px 1px 0px #000;
            background-color: var(--b-black, #000);
            color: var(--b-secondary, #ffdd00);
        }

        .brutal-btn:active:not(:disabled) {
            transform: translate(3px, 3px);
            box-shadow: 0px 0px 0px #000;
        }

    .brutal-border {
        border-style: solid !important;
        border-color: #000 !important;
        border-radius: 0 !important;
    }

    .hover-invert {
        transition: all 0.1s;
    }

        .hover-invert:hover {
            background-color: #000 !important;
            color: #fff !important;
        }

    .table-bordered > :not(caption) > * > * {
        border-width: 1px 2px;
    }

    input[type=number]::-webkit-inner-spin-button,
    input[type=number]::-webkit-outer-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }

    input[type=number] {
        -moz-appearance: textfield;
    }
</style>

@section Scripts {
    <script>
        (function(){
            const dec = document.getElementById('decQty'), inc = document.getElementById('incQty');
            const qty = document.getElementById('qtyInput'), formQty = document.getElementById('formQuantity');

            dec?.addEventListener('click', ()=> { let v = Math.max(1, parseInt(qty.value||'1')-1); qty.value = v; formQty.value = v; });
            inc?.addEventListener('click', ()=> { let v = Math.max(1, parseInt(qty.value||'1')+1); qty.value = v; formQty.value = v; });
            qty?.addEventListener('change', ()=> { let v = Math.max(1, parseInt(qty.value||'1')); qty.value = v; formQty.value = v; });

            document.querySelectorAll('[data-photo]').forEach(function(btn){
                btn.addEventListener('click', function(e){
                    e.preventDefault();
                    const photo = btn.getAttribute('data-photo');
                    if(photo){
                        const main = document.getElementById('mainProductImage');
                        const formPhoto = document.getElementById('formPhoto');
                        if(main) main.src = photo;
                        if(formPhoto) formPhoto.value = photo;
                    }
                });
            });

            const form = document.getElementById('frmAddToCart');
            if (form) {
                form.addEventListener('submit', async function (e) {
                    e.preventDefault();

                    const btn = document.getElementById('btnAddToCart');
                    const originalBtnContent = btn.innerHTML; // Lưu lại text cũ
                    btn.disabled = true;
                    btn.innerHTML = '<i class="fa-solid fa-spinner fa-spin me-2"></i> ĐANG THÊM...';

                    const fd = new FormData(form);

                    try {
                        const response = await fetch(form.action, {
                            method: 'POST',
                            body: fd,
                            credentials: 'same-origin'
                        });

                        let data = null;
                        const contentType = response.headers.get('content-type') || '';

                        if (contentType.indexOf('application/json') !== -1) {
                            data = await response.json();
                        } else {
                            const txt = await response.text();
                            try {
                                data = JSON.parse(txt);
                            } catch {
                                const m = txt.match(/\{[\s\S]*\}/);
                                if (m) {
                                    try { data = JSON.parse(m[0]); } catch { data = null; }
                                } else {
                                    data = null;
                                }
                            }
                        }

                        if (data && data.requiresLogin) {
                            const loginUrl = data.loginUrl || '/Account/Login';
                            const returnUrl = encodeURIComponent(window.location.pathname + window.location.search);
                            const sep = loginUrl.indexOf('?') >= 0 ? '&' : '?';
                            window.location.href = loginUrl + sep + 'ReturnUrl=' + returnUrl;
                            return;
                        }

                        if (response.ok && data && (data.success === true || data.success === "true")) {
                            if (data && typeof data.count !== 'undefined') {
                                try { window.setCartCount(Number(data.count)); } catch {}
                            } else {
                                try {
                                    const desktopBadge = document.getElementById('cartCount');
                                    const mobileBadge = document.getElementById('cartCountMobile');
                                    const added = parseInt(formQty.value || '1', 10) || 1;
                                    const updateBadge = (el) => {
                                        if (!el) return;
                                        const cur = parseInt(el.textContent || '0', 10) || 0;
                                        el.textContent = cur + added;
                                    };
                                    updateBadge(desktopBadge);
                                    updateBadge(mobileBadge);
                                    try {
                                        const curClient = parseInt(sessionStorage.getItem('lite_cart_count') || '0', 10) || 0;
                                        sessionStorage.setItem('lite_cart_count', (curClient + added).toString());
                                    } catch {}
                                } catch {}
                            }

                            btn.innerHTML = '<i class="fa-solid fa-check me-2"></i> ĐÃ THÊM';
                            btn.classList.add("bg-success", "text-white");

                            setTimeout(() => {
                                btn.innerHTML = originalBtnContent;
                                btn.disabled = false;
                                btn.classList.remove("bg-success");
                            }, 1500);

                        } else {
                            const msg = (data && data.message) ? data.message : 'Không thể thêm vào giỏ.';
                            alert(msg);
                            btn.innerHTML = originalBtnContent;
                            btn.disabled = false;
                        }
                    } catch (err) {
                        console.error(err);
                        alert('Lỗi mạng khi thêm vào giỏ.');
                        btn.innerHTML = originalBtnContent;
                        btn.disabled = false;
                    }
                });
            }
        })();
    </script>
}