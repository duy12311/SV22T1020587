@model SV22T1020587.Models.Common.PagedResult<SV22T1020587.Models.Catalog.Product>
@using SV22T1020587.Models.Catalog
@{
    ViewBag.Title = "Danh sách Sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var searchInput = ViewBag.SearchInput as ProductSearchInput ?? new ProductSearchInput { Page = 1, PageSize = 12, CategoryID = 0, SearchValue = "", MinPrice = 0, MaxPrice = 0 };
    int currentPage = Model.Page;
    int pageSize = Model.PageSize;
    int rowCount = Model.RowCount;
    int pageCount = pageSize > 0 ? (int)System.Math.Ceiling((double)rowCount / pageSize) : 1;
}

<div class="container-fluid p-0 mb-4 mt-2">

    <div class="d-flex flex-column flex-md-row justify-content-between align-items-md-center mb-3 border-bottom border-dark border-3 pb-2">
        <h2 class="fw-black text-uppercase m-0" style="font-size: clamp(1.5rem, 3vw, 2.2rem); letter-spacing: -1px;">
            <i class="bi bi-box-seam-fill text-primary"></i> KHO HÀNG
        </h2>
        <a class="brutal-border border-2 bg-white text-dark px-3 py-1 fw-bold text-decoration-none hover-invert mt-2 mt-md-0 w-auto small" asp-controller="Home" asp-action="Index">
            <i class="bi bi-arrow-left me-1"></i> TRỞ VỀ
        </a>
    </div>

    <div class="row g-3">
        <div class="col-lg-3 col-xl-2">
            <div class="brutal-border border-3 bg-light p-3 position-sticky" style="top: 80px; box-shadow: 4px 4px 0px #000; z-index: 10;">
                <h6 class="fw-black text-uppercase mb-3 pb-2 border-bottom border-dark border-2">
                    <i class="bi bi-funnel-fill"></i> BỘ LỌC
                </h6>

                <form method="get" asp-action="Index" class="d-flex flex-column gap-2">
                    <div>
                        <label class="form-label fw-bold text-uppercase small mb-1" style="font-size: 0.8rem;">Tìm theo tên</label>
                        <input name="SearchValue" value="@searchInput.SearchValue" class="form-control form-control-sm brutal-input" placeholder="Tên sản phẩm..." />
                    </div>

                    <div>
                        <label class="form-label fw-bold text-uppercase small mb-1" style="font-size: 0.8rem;">Loại hàng</label>
                        <select name="CategoryID" class="form-select form-select-sm brutal-input fw-bold">
                            <option value="0">-- TẤT CẢ --</option>
                            @foreach (var c in ViewBag.Categories as IEnumerable<Category> ?? Enumerable.Empty<Category>())
                            {
                                <option value="@c.CategoryID" selected="@(c.CategoryID == searchInput.CategoryID ? "selected" : null)">@c.CategoryName.ToUpper()</option>
                            }
                        </select>
                    </div>

                    <div>
                        <label class="form-label fw-bold text-uppercase small mb-1" style="font-size: 0.8rem;">Giá từ (VNĐ)</label>
                        <input name="MinPrice" type="number" min="0" value="@(searchInput.MinPrice)" class="form-control form-control-sm brutal-input fw-bold" placeholder="0" />
                    </div>

                    <div>
                        <label class="form-label fw-bold text-uppercase small mb-1" style="font-size: 0.8rem;">Đến giá (VNĐ)</label>
                        <input name="MaxPrice" type="number" min="0" value="@(searchInput.MaxPrice)" class="form-control form-control-sm brutal-input fw-bold" placeholder="Không giới hạn" />
                    </div>

                    <input type="hidden" name="PageSize" value="@searchInput.PageSize" />

                    <button type="submit" class="brutal-btn py-2 mt-2 fw-black text-uppercase w-100" style="font-size: 0.9rem;">
                        <i class="bi bi-search me-1"></i> TÌM KIẾM
                    </button>
                </form>
            </div>
        </div>

        <div class="col-lg-9 col-xl-10">

            @if (!Model.DataItems.Any())
            {
                <div class="brutal-border border-3 bg-white p-4 text-center w-100" style="box-shadow: 4px 4px 0px #000;">
                    <i class="bi bi-emoji-frown display-4 mb-2"></i>
                    <h4 class="fw-black text-uppercase">Không tìm thấy sản phẩm!</h4>
                    <p class="fw-bold mb-0">Hãy thử đổi điều kiện lọc.</p>
                </div>
            }
            else
            {
                <div class="row row-cols-2 row-cols-md-3 row-cols-xl-4 g-3">
                    @foreach (var p in Model.DataItems)
                    {
                        var photo = string.IsNullOrEmpty(p.Photo) ? "/images/no-image.png" : (p.Photo.StartsWith("http") ? p.Photo : Url.Content($"~/images/products/{p.Photo}"));

                        <div class="col">
                            <div class="brutal-border border-2 bg-white h-100 d-flex flex-column position-relative product-card-hover" style="box-shadow: 3px 3px 0px #000;">
                                <div class="position-absolute top-0 end-0 bg-primary text-white fw-bold px-2 brutal-border border-1 m-1 z-1" style="font-size: 0.7rem;">
                                    ID: @p.ProductID
                                </div>

                                <div class="border-bottom border-dark border-2 bg-light p-2 d-flex justify-content-center align-items-center" style="height: 170px;">
                                    <img src="@photo" class="img-fluid" alt="@p.ProductName" style="max-height: 100%; object-fit: contain; mix-blend-mode: multiply;" />
                                </div>

                                <div class="p-2 d-flex flex-column flex-grow-1">
                                    <h6 class="fw-black text-uppercase mb-2 text-truncate-2" title="@p.ProductName" style="font-size: 0.9rem; line-height: 1.3;">
                                        @p.ProductName
                                    </h6>

                                    <div class="mt-auto d-flex flex-column gap-2">
                                        <div class="text-center">
                                            <span class="fw-black text-primary" style="font-size: 1rem;">@p.Price.ToString("N0") đ</span>
                                        </div>

                                        <a asp-action="Details" asp-route-id="@p.ProductID" class="brutal-border border-2 bg-dark text-white text-center fw-bold py-1 px-2 text-decoration-none hover-invert w-100" style="font-size: 0.8rem;">
                                            CHI TIẾT
                                        </a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                @if (pageSize > 0 && pageCount > 1)
                {
                    int window = 2;
                    int startPage = System.Math.Max(1, currentPage - window);
                    int endPage = System.Math.Min(pageCount, currentPage + window);

                    <nav class="mt-4 d-flex justify-content-center" aria-label="Page navigation">
                        <ul class="pagination pagination-sm flex-wrap gap-1 m-0 brutal-pagination">

                            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                                <a class="page-link brutal-border border-2 fw-black text-dark"
                                   asp-action="Index"
                                   asp-route-Page="@(currentPage - 1)"
                                   asp-route-SearchValue="@searchInput.SearchValue"
                                   asp-route-CategoryID="@searchInput.CategoryID"
                                   asp-route-MinPrice="@searchInput.MinPrice"
                                   asp-route-MaxPrice="@searchInput.MaxPrice"
                                   asp-route-PageSize="@pageSize">
                                    <i class="bi bi-chevron-left"></i>
                                </a>
                            </li>

                            @if (startPage > 1)
                            {
                                <li class="page-item">
                                    <a class="page-link brutal-border border-2 fw-black text-dark"
                                       asp-action="Index"
                                       asp-route-Page="1"
                                       asp-route-SearchValue="@searchInput.SearchValue"
                                       asp-route-CategoryID="@searchInput.CategoryID"
                                       asp-route-MinPrice="@searchInput.MinPrice"
                                       asp-route-MaxPrice="@searchInput.MaxPrice"
                                       asp-route-PageSize="@pageSize">1</a>
                                </li>
                                @if (startPage > 2)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link brutal-border border-2 bg-light text-muted fw-black px-1">...</span>
                                    </li>
                                }
                            }

                            @for (int i = startPage; i <= endPage; i++)
                            {
                                <li class="page-item @(i == currentPage ? "active" : "")">
                                    <a class="page-link brutal-border border-2 fw-black"
                                       asp-action="Index"
                                       asp-route-Page="@i"
                                       asp-route-SearchValue="@searchInput.SearchValue"
                                       asp-route-CategoryID="@searchInput.CategoryID"
                                       asp-route-MinPrice="@searchInput.MinPrice"
                                       asp-route-MaxPrice="@searchInput.MaxPrice"
                                       asp-route-PageSize="@pageSize">@i</a>
                                </li>
                            }

                            @if (endPage < pageCount)
                            {
                                @if (endPage < pageCount - 1)
                                {
                                    <li class="page-item disabled">
                                        <span class="page-link brutal-border border-2 bg-light text-muted fw-black px-1">...</span>
                                    </li>
                                }
                                <li class="page-item">
                                    <a class="page-link brutal-border border-2 fw-black text-dark"
                                       asp-action="Index"
                                       asp-route-Page="@pageCount"
                                       asp-route-SearchValue="@searchInput.SearchValue"
                                       asp-route-CategoryID="@searchInput.CategoryID"
                                       asp-route-MinPrice="@searchInput.MinPrice"
                                       asp-route-MaxPrice="@searchInput.MaxPrice"
                                       asp-route-PageSize="@pageSize">@pageCount</a>
                                </li>
                            }

                            <li class="page-item @(currentPage == pageCount ? "disabled" : "")">
                                <a class="page-link brutal-border border-2 fw-black text-dark"
                                   asp-action="Index"
                                   asp-route-Page="@(currentPage + 1)"
                                   asp-route-SearchValue="@searchInput.SearchValue"
                                   asp-route-CategoryID="@searchInput.CategoryID"
                                   asp-route-MinPrice="@searchInput.MinPrice"
                                   asp-route-MaxPrice="@searchInput.MaxPrice"
                                   asp-route-PageSize="@pageSize">
                                    <i class="bi bi-chevron-right"></i>
                                </a>
                            </li>

                        </ul>
                    </nav>
                }
            }
        </div>
    </div>
</div>

<style>
    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .brutal-input {
        border: 2px solid #000 !important;
        border-radius: 0 !important;
        box-shadow: 2px 2px 0px rgba(0,0,0,0.1) !important;
        transition: all 0.2s ease;
    }

        .brutal-input:focus {
            outline: none !important;
            box-shadow: 3px 3px 0px var(--b-primary) !important;
            border-color: #000 !important;
        }

    .product-card-hover {
        transition: transform 0.2s, box-shadow 0.2s;
    }

        .product-card-hover:hover {
            transform: translate(-3px, -3px);
            box-shadow: 6px 6px 0px #000 !important;
        }

    .hover-invert {
        transition: all 0.1s;
    }

        .hover-invert:hover {
            background-color: var(--b-primary) !important;
            color: #fff !important;
            border-color: #000 !important;
        }

    .brutal-pagination .page-link {
        border-radius: 0 !important;
        background-color: #fff;
        color: #000;
        min-width: 32px;
        padding: 4px 8px;
        text-align: center;
        transition: all 0.1s;
    }

    .brutal-pagination .page-item:not(.active):not(.disabled) .page-link:hover {
        background-color: var(--b-black);
        color: var(--b-secondary);
        transform: translate(-1px, -1px);
        box-shadow: 2px 2px 0px var(--b-primary);
    }

    .brutal-pagination .page-item.active .page-link {
        background-color: var(--b-black);
        color: var(--b-secondary);
        border-color: #000;
        box-shadow: 2px 2px 0px var(--b-primary);
        transform: translate(-1px, -1px);
    }

    .brutal-pagination .page-item.disabled .page-link {
        background-color: #e9ecef;
        box-shadow: none;
    }
</style>