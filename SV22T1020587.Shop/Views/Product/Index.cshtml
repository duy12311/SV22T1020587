@model SV22T1020587.Models.Common.PagedResult<SV22T1020587.Models.Catalog.Product>
@using SV22T1020587.Models.Catalog
@{
    ViewBag.Title = "Sản phẩm";
    Layout = "~/Views/Shared/_Layout.cshtml";

    var searchInput = ViewBag.SearchInput as ProductSearchInput ?? new ProductSearchInput { Page = 1, PageSize = 12, CategoryID = 0, SearchValue = "", MinPrice = 0, MaxPrice = 0 };
    int currentPage = Model.Page;
    int pageSize = Model.PageSize;
    int rowCount = Model.RowCount;
    int pageCount = pageSize > 0 ? (int)System.Math.Ceiling((double)rowCount / pageSize) : 1;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="mb-0">Sản phẩm</h4>
    <div>
        <a class="btn btn-outline-secondary btn-sm" asp-controller="Home" asp-action="Index">← Trở về</a>
    </div>
</div>

<form method="get" asp-action="Index" class="row g-2 align-items-end mb-4">
    <div class="col-md-4">
        <label class="form-label small">Tìm theo tên</label>
        <input name="SearchValue" value="@searchInput.SearchValue" class="form-control" placeholder="Tên sản phẩm..." />
    </div>

    <div class="col-md-3">
        <label class="form-label small">Loại hàng</label>
        <select name="CategoryID" class="form-select">
            <option value="0">-- Tất cả --</option>
            @foreach (var c in ViewBag.Categories as IEnumerable<Category> ?? Enumerable.Empty<Category>())
            {
                <option value="@c.CategoryID" selected="@(c.CategoryID == searchInput.CategoryID ? "selected" : null)">@c.CategoryName</option>
            }
        </select>
    </div>

    <div class="col-md-2">
        <label class="form-label small">Giá từ</label>
        <input name="MinPrice" type="number" min="0" value="@(searchInput.MinPrice)" class="form-control" />
    </div>

    <div class="col-md-2">
        <label class="form-label small">Đến</label>
        <input name="MaxPrice" type="number" min="0" value="@(searchInput.MaxPrice)" class="form-control" />
    </div>

    <div class="col-md-1 text-end">
        <button type="submit" class="btn btn-primary btn-sm">Tìm</button>
    </div>

    <input type="hidden" name="PageSize" value="@searchInput.PageSize" />
</form>

<div class="row row-cols-1 row-cols-md-3 g-3">
    @foreach (var p in Model.DataItems)
    {
        var photo = string.IsNullOrEmpty(p.Photo) ? "/images/no-image.png" : (p.Photo.StartsWith("http") ? p.Photo : Url.Content($"~/images/products/{p.Photo}"));
        <div class="col">
            <div class="card h-100">
                <img src="@photo" class="card-img-top" alt="@p.ProductName" style="object-fit:cover; height:200px;" />
                <div class="card-body">
                    <h5 class="card-title">@p.ProductName</h5>
                    <p class="card-text text-muted">Giá: @p.Price.ToString("N0") VND</p>
                    <a asp-action="Details" asp-route-id="@p.ProductID" class="btn btn-sm btn-primary">Xem</a>
                </div>
            </div>
        </div>
    }
</div>

@if (pageSize > 0 && pageCount > 1)
{
    int window = 2;
    int startPage = System.Math.Max(1, currentPage - window);
    int endPage = System.Math.Min(pageCount, currentPage + window);

    <nav class="mt-4" aria-label="Page navigation">
        <ul class="pagination justify-content-center flex-wrap">

            <li class="page-item @(currentPage == 1 ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-Page="@(currentPage - 1)"
                   asp-route-SearchValue="@searchInput.SearchValue"
                   asp-route-CategoryID="@searchInput.CategoryID"
                   asp-route-MinPrice="@searchInput.MinPrice"
                   asp-route-MaxPrice="@searchInput.MaxPrice"
                   asp-route-PageSize="@pageSize">‹</a>
            </li>

            @if (startPage > 1)
            {
                <li class="page-item">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-Page="1"
                       asp-route-SearchValue="@searchInput.SearchValue"
                       asp-route-CategoryID="@searchInput.CategoryID"
                       asp-route-MinPrice="@searchInput.MinPrice"
                       asp-route-MaxPrice="@searchInput.MaxPrice"
                       asp-route-PageSize="@pageSize">1</a>
                </li>
                @if (startPage > 2)
                {
                    <li class="page-item disabled"><span class="page-link border-0 text-muted">...</span></li>
                }
            }

            @for (int i = startPage; i <= endPage; i++)
            {
                <li class="page-item @(i == currentPage ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-Page="@i"
                       asp-route-SearchValue="@searchInput.SearchValue"
                       asp-route-CategoryID="@searchInput.CategoryID"
                       asp-route-MinPrice="@searchInput.MinPrice"
                       asp-route-MaxPrice="@searchInput.MaxPrice"
                       asp-route-PageSize="@pageSize">@i</a>
                </li>
            }

            @if (endPage < pageCount)
            {
                @if (endPage < pageCount - 1)
                {
                    <li class="page-item disabled"><span class="page-link border-0 text-muted">...</span></li>
                }
                <li class="page-item">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-Page="@pageCount"
                       asp-route-SearchValue="@searchInput.SearchValue"
                       asp-route-CategoryID="@searchInput.CategoryID"
                       asp-route-MinPrice="@searchInput.MinPrice"
                       asp-route-MaxPrice="@searchInput.MaxPrice"
                       asp-route-PageSize="@pageSize">@pageCount</a>
                </li>
            }

            <li class="page-item @(currentPage == pageCount ? "disabled" : "")">
                <a class="page-link"
                   asp-action="Index"
                   asp-route-Page="@(currentPage + 1)"
                   asp-route-SearchValue="@searchInput.SearchValue"
                   asp-route-CategoryID="@searchInput.CategoryID"
                   asp-route-MinPrice="@searchInput.MinPrice"
                   asp-route-MaxPrice="@searchInput.MaxPrice"
                   asp-route-PageSize="@pageSize">›</a>
            </li>

        </ul>
    </nav>
}