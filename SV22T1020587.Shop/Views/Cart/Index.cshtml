@using System.Security.Claims
@model IList<SV22T1020587.Models.Sales.CartItem>
@{
    ViewBag.Title = "Giỏ hàng";
    Layout = "~/Views/Shared/_Layout.cshtml";

    // If controller provided a CheckoutCustomer in ViewBag, use it to prefill modal fields.
    var checkoutCustomer = ViewBag.CheckoutCustomer;
}
<h3>Giỏ hàng</h3>

<div class="mb-3">
    <button type="button" class="btn btn-outline-secondary btn-sm" onclick="(history.length>1?history.back():window.location.href='/')">← Trở về</button>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">Giỏ hàng trống.</div>
}
else
{
    // Cần giữ lại Token để Fetch API dùng cho bảo mật
    @Html.AntiForgeryToken()

    <div class="table-responsive">
        <table class="table align-middle bg-white shadow-sm" id="cartTable">
            <thead>
                <tr>
                    <th style="width:32px;" class="text-center"><input type="checkbox" id="selectAll" /></th>
                    <th style="width:110px;">Hình ảnh</th>
                    <th>Sản phẩm</th>
                    <th class="text-end">Đơn giá</th>
                    <th style="width:150px;" class="text-center">Số lượng</th>
                    <th class="text-end">Thành tiền</th>
                    <th></th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr data-row-id="@item.ProductID">
                        <td class="text-center">
                            <input type="checkbox" name="selectedProductID" value="@item.ProductID" class="selectItem" />
                        </td>
                        <td>
                            <img src="@(string.IsNullOrEmpty(item.Photo) ? "/images/no-image.png" : item.Photo)" alt="@item.ProductName" class="img-fluid" style="max-width:96px;height:64px;object-fit:cover;">
                        </td>
                        <td>
                            <div class="fw-semibold">@item.ProductName</div>
                            <small class="text-muted">Mã: @item.ProductID</small>
                        </td>
                        <td class="text-end" data-price="@item.SalePrice">@String.Format("{0:N0}", item.SalePrice) VND</td>
                        <td class="text-center">
                            <div class="input-group input-group-sm" style="width:120px;margin:auto;">
                                <button class="btn btn-outline-secondary" type="button" onclick="changeQty(this,-1)">-</button>

                                <input type="number" value="@item.Quantity" min="1"
                                       class="form-control text-center input-quantity"
                                       data-product-id="@item.ProductID" />

                                <button class="btn btn-outline-secondary" type="button" onclick="changeQty(this,1)">+</button>
                            </div>
                        </td>
                        <td class="text-end item-total-price">@String.Format("{0:N0}", item.TotalPrice) VND</td>
                        <td class="text-end">
                            <button type="button" class="btn btn-sm btn-outline-danger btn-remove" data-product-id="@item.ProductID" title="Xóa">
                                <i class="fa-solid fa-trash"></i>
                            </button>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="d-flex justify-content-between align-items-center mt-3">
        <div>
            <a href="~/Product" class="btn btn-outline-secondary btn-rounded"><i class="fa-solid fa-arrow-left me-1"></i> Tiếp tục mua sắm</a>
            <button type="button" id="btnClearCart" class="btn btn-outline-danger btn-rounded ms-2">Xóa giỏ hàng</button>
        </div>
        <div class="text-end">
            <div class="mb-2">Tổng tiền: <span id="cart-total" class="fs-5 fw-bold text-danger">@String.Format("{0:N0}", Model.Sum(i => i.TotalPrice)) VND</span></div>

            @* Open checkout modal from cart, avoids nested forms and keeps UX in-cart *@
            <button type="button" id="btnProceedCheckout" class="btn btn-success btn-rounded btn-lg">Tiến hành đặt hàng</button>
        </div>
    </div>
}

@* Checkout modal: collects customer info and posts to Order/Init *@
<div class="modal fade" id="checkoutModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <form id="frmCheckoutModal">
                <div class="modal-header">
                    <h5 class="modal-title">Thanh toán — Thông tin giao hàng</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Đóng"></button>
                </div>
                <div class="modal-body">
                    @Html.AntiForgeryToken()
                    <div class="row g-3">
                        <div class="col-md-6">
                            <label class="form-label small">Họ và tên</label>
                            <input type="text" name="CustomerName" class="form-control" required value="@(checkoutCustomer?.CustomerName ?? User.Identity?.Name ?? String.Empty)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Số điện thoại</label>
                            <input type="tel" name="Phone" class="form-control" required value="@(checkoutCustomer?.Phone ?? String.Empty)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Tỉnh/Thành phố</label>
                            <input type="text" name="DeliveryProvince" class="form-control" required value="@(checkoutCustomer?.Province ?? String.Empty)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Địa chỉ chi tiết</label>
                            <input type="text" name="DeliveryAddress" class="form-control" required value="@(checkoutCustomer?.Address ?? String.Empty)" />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small">Phương thức thanh toán</label>
                            <select name="PaymentMethod" class="form-select" required>
                                <option value="cod">Thanh toán khi nhận hàng (COD)</option>
                                <option value="bank_transfer">Chuyển khoản</option>
                                <option value="card">Thẻ tín dụng / ghi nợ</option>
                            </select>
                        </div>
                        <div class="col-12">
                            <label class="form-label small">Ghi chú</label>
                            <textarea name="Note" class="form-control" rows="2"></textarea>
                        </div>
                    </div>

                    <div id="checkoutAlert" class="alert alert-danger mt-3 d-none" role="alert"></div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Hủy</button>
                    <button type="submit" class="btn btn-primary">Xác nhận đặt hàng</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Hàm tính toán và cập nhật lại giao diện ngay lập tức
        function recalculateCartUI() {
            let totalCart = 0;
            document.querySelectorAll('#cartTable tbody tr').forEach(row => {
                const qtyInput = row.querySelector('.input-quantity');
                if (!qtyInput) return;

                const qty = parseInt(qtyInput.value) || 0;
                const priceCell = row.querySelector('[data-price]');
                const price = parseFloat(priceCell.getAttribute('data-price')) || 0;

                // Cập nhật thành tiền từng dòng
                const rowTotal = qty * price;
                row.querySelector('.item-total-price').textContent = new Intl.NumberFormat('vi-VN').format(rowTotal) + " VND";

                // Cộng dồn vào tổng
                totalCart += rowTotal;
            });

            // Cập nhật tổng tiền toàn giỏ hàng
            const totalEl = document.getElementById('cart-total');
            if (totalEl) totalEl.textContent = new Intl.NumberFormat('vi-VN').format(totalCart) + " VND";
        }

        // Tăng giảm số lượng bằng nút +/-
        function changeQty(btn, delta) {
            var input = btn.parentElement.querySelector('input[type="number"]');
            var v = parseInt(input.value || '1', 10) + delta;
            if (v < 1) return; // Nếu < 1 thì không làm gì (xóa dùng nút riêng)
            input.value = v;

            // Kích hoạt sự kiện change để gọi Ajax bên dưới
            input.dispatchEvent(new Event('change'));
        }

        // BẮT SỰ KIỆN CẬP NHẬT SỐ LƯỢNG (AJAX)
        document.querySelectorAll('.input-quantity').forEach(input => {
            input.addEventListener('change', async function() {
                const productId = this.dataset.productId;
                const qty = parseInt(this.value);

                if (qty < 1) {
                    this.value = 1;
                    return;
                }

                // Cập nhật giao diện tạm thời trước để có cảm giác mượt
                recalculateCartUI();

                try {
                    const response = await fetch('/Cart/Update', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: `productID=${productId}&quantity=${qty}`
                    });
                    const result = await response.json();

                    if (result.success && typeof window.refreshCartBadge === 'function') {
                        window.refreshCartBadge(); // Hàm này nằm trong file app.js (hoặc script layout) bạn khai báo ban đầu
                    }
                } catch (err) {
                    console.error("Lỗi cập nhật:", err);
                    alert("Có lỗi khi cập nhật số lượng!");
                }
            });
        });

        // BẮT SỰ KIỆN XÓA 1 SẢN PHẨM (AJAX)
        document.querySelectorAll('.btn-remove').forEach(btn => {
            btn.addEventListener('click', async function(e) {
                e.preventDefault();
                const productId = this.dataset.productId;

                if (!confirm("Bạn có chắc chắn muốn xóa sản phẩm này khỏi giỏ hàng?")) return;

                try {
                    const response = await fetch('/Cart/Remove', {
                        method: 'POST',
                        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
                        body: `productID=${productId}`
                    });
                    const result = await response.json();

                    if (result.success) {
                        // Xóa dòng HTML tương ứng
                        const row = document.querySelector(`tr[data-row-id="${productId}"]`);
                        if (row) row.remove();

                        // Tính lại tổng tiền
                        recalculateCartUI();

                        // Update badge
                        if (typeof window.refreshCartBadge === 'function') window.refreshCartBadge();

                        // Nếu hết sản phẩm trong bảng, reload lại trang để hiện "Giỏ hàng trống"
                        if (document.querySelectorAll('#cartTable tbody tr').length === 0) {
                            window.location.reload();
                        }
                    }
                } catch (err) {
                    console.error("Lỗi xóa mặt hàng:", err);
                }
            });
        });

        // ================= GIỮ NGUYÊN CÁC SỰ KIỆN CŨ CỦA BẠN =================

        document.getElementById('selectAll')?.addEventListener('change', function(e){
            var checked = e.target.checked;
            document.querySelectorAll('.selectItem').forEach(function(cb){ cb.checked = checked; });
        });

        document.getElementById('btnClearCart')?.addEventListener('click', function(){
            if (!confirm('Xóa toàn bộ giỏ hàng?')) return;
            fetch('/Cart/Clear', { method: 'POST', credentials: 'same-origin', headers: {'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value } })
            .then(()=> window.location.reload());
        });

        document.getElementById('btnProceedCheckout')?.addEventListener('click', async function(){
            var checked = Array.from(document.querySelectorAll('.selectItem:checked')).map(function(cb){ return cb.value; });

            try {
                if (checked.length > 0) {
                    var qs = checked.map(id => 'selectedProductID=' + encodeURIComponent(id)).join('&');
                    await fetch('/Order/Checkout?' + qs, { method: 'GET', credentials: 'same-origin' });
                }
                var modalEl = document.getElementById('checkoutModal');
                var modal = bootstrap.Modal.getOrCreateInstance(modalEl);
                modal.show();
            } catch (ex) {
                console.error(ex);
                alert('Không thể mở form thanh toán. Vui lòng thử lại.');
            }
        });

        document.getElementById('frmCheckoutModal')?.addEventListener('submit', async function (e) {
            e.preventDefault();
            var alertEl = document.getElementById('checkoutAlert');
            alertEl.classList.add('d-none');
            alertEl.textContent = '';

            var form = e.target;
            var tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            var token = tokenInput ? tokenInput.value : '';

            var formData = new FormData(form);
            if (token) formData.set('__RequestVerificationToken', token);

            try {
                var resp = await fetch('/Order/Init', {
                    method: 'POST',
                    credentials: 'same-origin',
                    body: formData
                });

                if (resp.redirected) {
                    window.location.href = resp.url;
                    return;
                }

                var contentType = resp.headers.get('content-type') || '';
                if (resp.ok && contentType.indexOf('text/html') !== -1) {
                    var html = await resp.text();
                    var parser = new DOMParser();
                    var doc = parser.parseFromString(html, 'text/html');
                    var newBody = doc.querySelector('.modal-body') || doc.querySelector('form');
                    if (newBody) {
                        document.querySelector('#checkoutModal .modal-body').innerHTML = newBody.innerHTML;
                    } else {
                        document.open();
                        document.write(html);
                        document.close();
                    }
                    return;
                }

                if (!resp.ok) {
                    var text = await resp.text();
                    alert(text || 'Lỗi khi đặt hàng');
                    return;
                }

                window.location.href = '/Order/Success';
            } catch (ex) {
                console.error(ex);
                alert('Lỗi hệ thống khi gửi đơn. Vui lòng thử lại.');
            }
        });
    </script>
}