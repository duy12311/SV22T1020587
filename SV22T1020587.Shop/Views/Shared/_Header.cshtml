@using System.Security.Claims
@{
    var userName = User?.Identity?.IsAuthenticated == true ? User.Identity.Name : null;
    var claimEmail = User?.FindFirst(ClaimTypes.Email)?.Value ?? "";
    var claimDisplayName = User?.FindFirst(ClaimTypes.Name)?.Value ?? userName ?? "Khách";
}

<header class="header-navbar fixed-top bg-white border-bottom border-dark border-3 shadow-sm" style="top: 0; padding: 12px 0;">
    <div class="container-fluid px-4">
        <div class="row align-items-center">

            <div class="col-4 d-flex align-items-center">
                <a class="text-decoration-none" href="~/">
                    <div class="fw-black text-dark" style="font-weight: 900; font-size: 1.6rem; letter-spacing: -2px;">
                        DPM<span class="bg-dark text-white px-2 ms-1 border border-dark border-2" style="box-shadow: 2px 2px 0 #FF0055;">ENT.</span>
                    </div>
                </a>
            </div>

            <div class="col-4 d-none d-md-flex justify-content-center">
                <nav class="d-flex align-items-center gap-2">
                    <a href="~/" class="brutal-nav-link px-4 py-2 text-decoration-none fw-black text-uppercase">
                        TRANG CHỦ
                    </a>
                    <a href="~/Product" class="brutal-nav-link px-4 py-2 text-decoration-none fw-black text-uppercase">
                        SẢN PHẨM
                    </a>
                </nav>
            </div>

            <div class="col-8 col-md-4 d-flex align-items-center justify-content-end gap-2 gap-md-3">

                <a class="position-relative text-dark text-decoration-none p-2 brutal-border bg-white d-flex align-items-center justify-content-center" href="~/Cart" style="width: 42px; height: 42px;">
                    <i class="bi bi-cart-fill fs-5"></i>
                    <span id="cartCount" class="cart-badge badge bg-danger text-white border border-2 border-dark rounded-0 position-absolute" style="top: -8px; right: -8px; font-weight: 900; font-size: 0.7rem;">
                        0
                    </span>
                </a>

                @if (userName != null)
                {
                    <div class="dropdown">
                        <div class="brutal-border bg-white px-3 py-2 d-flex align-items-center" data-bs-toggle="dropdown" style="cursor: pointer;">
                            <img src="https://ui-avatars.com/api/?name=@userName&background=000&color=00FF66&rounded=false" class="me-2 border border-dark" width="24" height="24">
                            <span class="fw-bold text-uppercase d-none d-lg-inline small">@claimDisplayName</span>
                        </div>
                        <ul class="dropdown-menu dropdown-menu-end mt-2 brutal-border rounded-0 shadow-none p-0 overflow-hidden">
                            <li class="px-3 py-2 small text-muted border-bottom border-dark bg-light fw-bold" style="word-break: break-all;">@claimEmail</li>
                            <li><a class="dropdown-item py-2 fw-bold small" href="~/Account/Profile">HỒ SƠ</a></li>
                            <li><a class="dropdown-item py-2 fw-bold small text-danger" href="~/Order/MyOrders">ĐƠN HÀNG</a></li>
                            <li>
                                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0 border-top border-dark">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="dropdown-item py-2 fw-black border-0 bg-transparent w-100 text-start small text-uppercase">
                                        ĐĂNG XUẤT
                                    </button>
                                </form>
                            </li>
                        </ul>
                    </div>
                }
                else
                {
                    <div class="d-none d-md-flex gap-2">
                        <a class="brutal-btn bg-warning text-dark px-3 py-2 text-decoration-none small" href="~/Account/Login">ĐĂNG NHẬP</a>
                        <a class="brutal-btn bg-white text-dark px-3 py-2 text-decoration-none small" href="~/Account/Register">ĐĂNG KÝ</a>
                    </div>
                    <a class="brutal-border bg-dark text-white p-2 d-md-none text-decoration-none" href="~/Account/Login"><i class="bi bi-person-fill fs-5"></i></a>
                }
            </div>

        </div>
    </div>
</header>

<style>
    body {
        padding-top: 85px;
    }

    .fw-black {
        font-weight: 900 !important;
    }

    .brutal-nav-link {
        color: #000;
        border: 2px solid transparent;
        font-size: 0.85rem;
        transition: all 0.1s ease;
        border-radius: 0;
    }

        .brutal-nav-link:hover {
            background-color: #ffdd00; 
            border-color: #000;
            box-shadow: 4px 4px 0px #000;
            transform: translate(-2px, -2px);
        }

    .brutal-border {
        border: 2px solid #000 !important;
        border-radius: 0 !important;
    }

    .brutal-btn {
        border: 2px solid #000;
        border-radius: 0;
        font-weight: 900;
        box-shadow: 3px 3px 0 #000;
        text-transform: uppercase;
        transition: all 0.1s;
    }

        .brutal-btn:hover {
            transform: translate(1px, 1px);
            box-shadow: 1px 1px 0 #000;
            background-color: #000 !important;
            color: #fff !important;
        }

    .fixed-top {
        position: fixed;
        top: 0;
        right: 0;
        left: 0;
        z-index: 1030;
    }

    .dropdown-item:hover {
        background-color: #000;
        color: #fff !important;
    }
</style>