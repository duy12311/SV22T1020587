@model List<SV22T1020587.Models.Catalog.Product>
@{
    ViewBag.Title = "DPM ENT.";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="home-hero mb-4 mt-2">
    <div class="brutal-border border-4 bg-white d-flex flex-column flex-lg-row">

        <div class="d-none d-lg-flex align-items-center justify-content-center p-2 border-end border-dark border-4" style="background-color: var(--b-secondary); width: 60px;">
            <h1 class="fw-black m-0 text-uppercase" style="writing-mode: vertical-rl; transform: rotate(180deg); font-size: 1.5rem; letter-spacing: -1px;">
                DPM ENTERTAINMENT
            </h1>
        </div>

        <div class="position-relative border-end-lg border-dark border-4 flex-grow-1 border-bottom border-lg-bottom-0 border-dark">
            <img src="https://images.unsplash.com/photo-1498050108023-c5249f4df085?q=80&w=1000&auto=format&fit=crop"
                 class="w-100 h-100 object-fit-cover"
                 style="min-height: 300px; max-height: 350px; filter: grayscale(1) contrast(1.2);" alt="Banner">

            <div class="position-absolute bottom-0 start-0 w-100 bg-black text-white p-2 border-top border-dark border-3 d-flex justify-content-between align-items-center">
                <h3 class="fw-black m-0 text-uppercase fs-5" style="color: var(--b-primary); text-shadow: 1px 1px 0 #fff;">GIẢM 40% TUẦN LỄ GAMING</h3>
                <i class="bi bi-controller fs-3 d-none d-md-block text-white"></i>
            </div>
        </div>

        <div class="p-3 p-lg-4 d-flex flex-column justify-content-center" style="width: 100%; max-width: 350px; background-image: radial-gradient(#aaa 2px, transparent 2px); background-size: 15px 15px;">
            <h2 class="fw-black fs-3 text-uppercase mb-3 bg-white brutal-border p-2 d-inline-block" style="transform: rotate(-2deg);">
                KHÔNG <br /> ĐỤNG HÀNG
            </h2>
            <p class="fs-6 fw-bold bg-white brutal-border p-2 mb-3 shadow-none">
                Trải nghiệm mua sắm đỉnh cao. Thiết bị công nghệ hàng đầu. Giao hàng thần tốc.
            </p>
            <div class="d-flex flex-column gap-2 mt-auto">
                <a href="~/Product" class="brutal-btn py-2 fs-6 text-center text-decoration-none">
                    <i class="bi bi-cart-plus-fill me-2"></i> MUA NGAY
                </a>
                <a href="#featured" class="brutal-border bg-white text-dark py-2 fs-6 fw-bold text-center text-decoration-none hover-invert">
                    KHÁM PHÁ <i class="bi bi-arrow-down"></i>
                </a>
            </div>
        </div>

    </div>
</section>

<div class="container-fluid p-0 mb-5" id="featured">
    <div class="row g-4">

        <div class="col-lg-3">
            <div class="position-sticky" style="top: 130px; z-index: 10;">
                <div class="brutal-border bg-primary text-white p-3 d-flex flex-row flex-lg-column justify-content-between align-items-lg-start align-items-center">
                    <div>
                        <i class="bi bi-fire fs-1 text-dark" style="text-shadow: 2px 2px 0 #fff;"></i>
                        <h2 class="fw-black fs-2 text-uppercase mt-lg-2 mb-0 mb-lg-3" style="line-height: 1.1; letter-spacing: -1px;">
                            HÀNG<br class="d-none d-lg-block" /> TUYỂN<br class="d-none d-lg-block" /> CHIẾN<br class="d-none d-lg-block" /> NHẤT
                        </h2>
                    </div>
                    <a href="~/Product" class="brutal-border bg-black text-white text-decoration-none fw-bold px-3 py-2 d-inline-block text-center hover-neon w-100 mt-lg-3">
                        TẤT CẢ <i class="bi bi-arrow-right"></i>
                    </a>
                </div>
            </div>
        </div>

        <div class="col-lg-9">
            <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-3">
                @if (Model == null || !Model.Any())
                {
                    <div class="col-12 text-center py-5 brutal-border bg-white w-100">
                        <i class="bi bi-box-seam display-1 text-dark mb-3"></i>
                        <h4 class="fw-black text-uppercase">Kho Hàng Đang Trống!</h4>
                        <p class="fw-bold fs-6">Ông chủ đang đi nhập hàng nóng, vui lòng quay lại sau.</p>
                    </div>
                }
                else
                {
                    foreach (var p in Model)
                    {
                        var photo = string.IsNullOrEmpty(p.Photo) ? "/images/no-image.png" : (p.Photo.StartsWith("http") ? p.Photo : Url.Content($"~/images/products/{p.Photo}"));
                        <div class="col">
                            <div class="brutal-border bg-white h-100 d-flex flex-column position-relative">
                                <div class="position-absolute top-0 end-0 bg-dark text-secondary fw-black px-2 py-1 brutal-border border-0 m-2 z-1" style="font-size: 0.8rem;">
                                    NEW
                                </div>

                                <div class="border-bottom border-dark border-3 bg-light p-2 d-flex justify-content-center align-items-center" style="height: 220px;">
                                    <img src="@photo" class="img-fluid" alt="@p.ProductName" style="max-height: 100%; object-fit: contain; mix-blend-mode: multiply;" />
                                </div>

                                <div class="p-3 d-flex flex-column flex-grow-1">
                                    <h5 class="fw-black text-uppercase mb-2 text-truncate-2" title="@p.ProductName" style="font-size: 1.1rem; line-height: 1.3;">@p.ProductName</h5>

                                    <div class="mt-auto d-flex flex-column gap-2">
                                        <div class="brutal-border bg-light px-2 py-1 text-center">
                                            <span class="fw-black fs-5 text-dark">@p.Price.ToString("N0") VNĐ</span>
                                        </div>

                                        <div class="d-flex gap-2">
                                            <a asp-controller="Product" asp-action="Details" asp-route-id="@p.ProductID" class="brutal-border bg-white text-dark text-center fw-bold py-1 px-3 text-decoration-none hover-invert" title="Xem chi tiết">
                                                <i class="bi bi-eye-fill"></i>
                                            </a>
                                            <button type="button" class="brutal-btn flex-fill py-1 fw-bold" style="font-size: 0.9rem;" onclick="addToCart(@p.ProductID, '@p.ProductName', @p.Price, '@p.Photo', 1)">
                                                THÊM VÀO GIỎ
                                            </button>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>

    </div>
</div>

<style>
    @@media (min-width: 992px) {
        .border-end-lg {
            border-right: var(--b-border) !important;
            border-right-width: 4px !important;
        }

        .border-lg-bottom-0 {
            border-bottom: none !important;
        }
    }

    .text-truncate-2 {
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .hover-invert {
        transition: all 0.1s;
    }

        .hover-invert:hover {
            background-color: var(--b-black) !important;
            color: var(--b-secondary) !important;
        }

    .hover-neon {
        transition: 0.2s;
    }

        .hover-neon:hover {
            color: var(--b-secondary) !important;
            padding-left: 10px;
        }
</style>