@model List<SV22T1020587.Models.Catalog.Product>
@{
    ViewBag.Title = "Trang chủ";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<section class="home-hero">
    <div class="container">
        <div class="row align-items-center">
            <div class="col-md-7">
                <div class="hero-card">
                    <h1 class="display-5">Chào mừng đến với     <br /> Dopamine EnT</h1>
                    <p class="lead text-muted">Mua sắm nhanh chóng — sản phẩm chất lượng — giao hàng tận nơi.</p>

                    <div class="d-flex gap-2 mt-3">
                        <a href="~/Product" class="btn btn-primary btn-lg">Mua ngay</a>
                    </div>

                    <div class="mt-4 text-muted">
                        <small><i class="bi bi-truck me-1"></i> Miễn phí vận chuyển cho đơn hàng trên 1,000,000 VND</small>
                    </div>
                </div>
            </div>

            <div class="col-md-5">
                <div class="card hero-card">
                    <div class="card-body text-center">
                        <h6>Khách hàng</h6>
                        <p class="mb-2">Quản lý đơn hàng, theo dõi giao hàng và truy cập lịch sử mua sắm của bạn.</p>
                        <a href="~/Profile" class="btn btn-outline-primary">Xem hồ sơ</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="container my-5">
    <h4 class="mb-3">Danh mục nổi bật</h4>
    <div class="row row-cols-1 row-cols-md-3 g-3">
        @if (Model == null || !Model.Any())
        {
            <div class="col">
                <div class="card h-100">
                    <img src="/images/no-image.png" class="card-img-top" alt="sample" />
                    <div class="card-body">
                        <h5 class="card-title">Không có sản phẩm nổi bật</h5>
                    </div>
                </div>
            </div>
        }
        else
        {
            foreach (var p in Model)
            {
                var photo = string.IsNullOrEmpty(p.Photo) ? "/images/no-image.png" : (p.Photo.StartsWith("http") ? p.Photo : Url.Content($"~/images/products/{p.Photo}"));
                <div class="col">
                    <div class="card h-100">
                        <img src="@photo" class="card-img-top" alt="@p.ProductName" style="object-fit:cover; height:200px;" />
                        <div class="card-body">
                            <h5 class="card-title">@p.ProductName</h5>
                            <p class="card-text text-muted">Giá: @p.Price.ToString("N0") VND</p>
                            <a asp-controller="Product" asp-action="Details" asp-route-id="@p.ProductID" class="btn btn-sm btn-primary">Xem</a>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>
