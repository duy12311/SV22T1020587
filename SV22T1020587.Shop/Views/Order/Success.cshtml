@{
    ViewBag.Title = "Đặt hàng thành công";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container mt-5 mb-5 text-center">
    <div class="mb-4">
        <i class="fa-solid fa-circle-check text-success" style="font-size: 80px;"></i>
    </div>

    <h2 class="text-success fw-bold">Đặt hàng thành công!</h2>
    <p class="lead mt-3">Cảm ơn bạn đã tin tưởng và mua sắm tại cửa hàng của chúng tôi.</p>
    <p class="text-muted">Đơn hàng của bạn đã được ghi nhận vào hệ thống và đang trong quá trình chờ xử lý. Chúng tôi sẽ sớm liên hệ với bạn.</p>

    <div class="mt-5">
        <a href="~/" class="btn btn-primary btn-lg rounded-pill px-4 me-2">
            <i class="fa-solid fa-house me-1"></i> Về trang chủ
        </a>
        <a href="~/Product" class="btn btn-outline-secondary btn-lg rounded-pill px-4">
            Tiếp tục mua sắm <i class="fa-solid fa-arrow-right ms-1"></i>
        </a>
    </div>
</div>