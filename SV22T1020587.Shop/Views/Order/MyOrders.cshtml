@model IEnumerable<SV22T1020587.Models.Sales.OrderViewInfo>
@{
    ViewBag.Title = "Đơn hàng của tôi";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<h3>Đơn hàng của tôi</h3>

<div class="mb-3">
    <a class="btn btn-outline-secondary btn-sm" asp-controller="Account" asp-action="Profile">← Trở về</a>
    <noscript><a href="~/Account/Profile" class="btn btn-outline-secondary btn-sm">← Trở về</a></noscript>
</div>

@if (Model == null || !Model.Any())
{
    <div class="alert alert-info">Bạn chưa có đơn hàng nào.</div>
}
else
{
    <table class="table table-hover">
        <thead>
            <tr>
                <th>Mã đơn</th>
                <th>Ngày</th>
                <th>Trạng thái</th>
                <th></th>
            </tr>
        </thead>
        <tbody>
            @foreach (var o in Model)
            {
                string badgeClass = o.Status switch
                {
                    1 => "bg-secondary",    // Chờ duyệt
                    2 => "bg-primary",      // Đã duyệt (Chờ giao hàng)
                    3 => "bg-info text-dark", // Đang giao hàng
                    4 => "bg-success",      // Thành công
                    -1 => "bg-danger",      // Đã hủy
                    -2 => "bg-dark",        // Bị từ chối
                    _ => "bg-light text-dark"
                };
                <tr>
                    <td>@o.OrderID</td>
                    <td>@o.OrderTime.ToString("g")</td>
                    <td>
                        <span class="badge @badgeClass">@o.StatusDescription</span>
                    </td>
                    <td class="text-end"><a class="btn btn-sm btn-outline-primary" href="~/Order/Detail/@o.OrderID">Xem</a></td>
                </tr>
            }
        </tbody>
    </table>
}